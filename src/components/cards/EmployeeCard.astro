---
import Heading from "../Heading.astro";
import LinkButton from "../../components/Buttons__&_links/LinkButton.astro";
import Text from "../Text.astro";
const { traener, xtraener, lokation, profil_img } = Astro.props;
const beggeTraener = xtraener ? `${traener} & ${traener}` : traener;
---

<article
  class="max-w-40 gap-2 rounded-md border border-(--main-400) md:max-w-70"
>
  <img
    src={profil_img}
    alt={beggeTraener}
    class="w-fill aspect-square h-auto object-cover object-[0%_20%] md:col-span-2"
  />
  <div class="grid px-2 pt-2 md:grid-cols-2 md:pb-4 md:pl-4">
    <div class="md:col-span-2">
      <Heading htmlheading="h6" size="h6" font="display" weight="semibold">
        {traener}
      </Heading>
      <Heading htmlheading="h6" size="h6" font="display" weight="semibold">
        {xtraener && ` & ${xtraener}`}
      </Heading>
    </div>
    <Text size="label_2" stylingclasses="tracking-wider">{lokation}</Text>
    <div class="m-auto flex flex-wrap pb-2 whitespace-pre md:pr-2">
      <LinkButton
        color="outline"
        href="#"
        label="SE PROFIL"
        stylingclasses="my-2"
      />
    </div>
  </div>
</article>
