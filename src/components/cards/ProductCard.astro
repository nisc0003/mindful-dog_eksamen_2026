---
import Heading from "../Heading.astro";
const { img, type, traener, path, lokation, hold, pris } = Astro.props;
---

<li class="mx-auto overflow-hidden rounded-md bg-(--neutral-100)">
  <a href={"/Hold_side/" + path}>
    <article class="row-span-2 grid grid-rows-subgrid">
      <img
        src={img}
        alt={type}
        class="aspect-3/2 h-auto w-[100cqw] object-cover object-[0%_20%]"
      />
      <div class="p-[2cqw]">
        <div
          class="[&_p]:text-size-10) flex gap-2 [&_p]:my-3 [&_p]:rounded-md [&_p]:px-3 [&_p]:py-1 [&_p]:text-center [&_p]:font-semibold"
        >
          <p class="bg-(--neutral-500) text-(--text-inverse)">
            {lokation}
          </p>
          <p class="bg-(--neutral-200) text-(--text-primary)">
            {type}
          </p>
          <p class="bg-(--neutral-200) text-(--text-primary)">{traener}</p>
        </div>
        <div>
          <Heading htmlheading="h6" size="h6" font="display" weight="bold">
            {hold}
          </Heading>
          <p class="text-size-16">
            Her skal der være en beskrivelse af holdet.
          </p>
        </div>
        <div class="my-4 flex items-center justify-between">
          <p class="text-size-20 font-bold">{pris}</p>
          <a
            href="/Hold_oversigt"
            class="text-size-20 rounded-md border-2 border-(--primary-500) bg-(--primary-500) px-4 py-2 text-(--text-main) transition-colors duration-150 hover:bg-(--accent-200)"
          >
            SE HOLD
          </a>
        </div>
      </div>
    </article>
  </a>
</li>
