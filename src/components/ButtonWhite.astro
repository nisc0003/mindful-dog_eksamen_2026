---
const {link, text} = Astro.props;
---

<a href={link} class="w-fit h-fit bg-neutral-100 text-neutral-700 border-2 border-neutral-950
 no-underline font-extrabold px-6 py-2 rounded-lg text-sm sm:text-lg
 transition-colors duration-300 hover:bg-neutral-950 hover:border-transparent hover:text-neutral-100   ">
    {text}
</a>
