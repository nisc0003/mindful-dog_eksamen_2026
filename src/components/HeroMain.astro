---
import Heading from "./Heading.astro";
import Text from "./Text.astro";
import LinkButton from "./Buttons__&_links/LinkButton.astro";

type HeroImage = {
  src: string;
  width: number;
  height: number;
};

type LinkButtonSize = "sm" | "md" | "lg" | "xl";
type LinkButtonColor =
  | "main"
  | "primary"
  | "secondary"
  | "accent"
  | "neutral"
  | "outline";

interface ButtonConfig {
  // Available LinkButton props that can be mapped into HeroMain buttons.
  label: string;
  color: LinkButtonColor;
  href: string;
  // Size variants from LinkButton. Use these when the mapped button should
  // differ from the default medium size.
  size?: LinkButtonSize;
  stylingclasses?: string;
  target?: string;
  rel?: string;
}

interface Props {
  // Optional breadcrumb line above the hero title.
  breadcrumbs?: string;
  // Hero title as HTML so line breaks and spans can be mapped in data.
  titleHtml: string;
  // Optional supporting text below the title.
  subtitle?: string;
  // Accepts either an Astro image object or a plain string URL.
  imageSrc: HeroImage | string;
  imageAlt?: string;
  // Optional extra classes applied to the image element (e.g. flip)
  imageClass?: string;
  // Optional extra classes applied to the image wrapper.
  imageWrapperClass?: string;
  // Optional layout overrides for page-specific hero tuning.
  layoutGapClass?: string;
  contentGapClass?: string;
  titleClass?: string;
  subtitleClass?: string;
  buttons?: ButtonConfig[];
}

const {
  breadcrumbs,
  titleHtml,
  subtitle,
  imageSrc,
  imageAlt = "Hero transparent billede",
  imageClass = "",
  imageWrapperClass = "",
  layoutGapClass = "gap-8 md:gap-12 lg:gap-20",
  contentGapClass = "gap-4 md:gap-6",
  titleClass = "",
  subtitleClass = "",
  buttons = [],
} = Astro.props as Props;

const imgSrc = typeof imageSrc === "string" ? imageSrc : imageSrc.src;
---

<!-- No section/padding here — the page owns spacing via px-(--page-space-inline) py-(--section-space-y) -->
<div
  class={`grid w-full grid-cols-1 ${layoutGapClass} md:grid-cols-[3fr_2fr] md:items-center`}
>
  <!-- Text column -->
  <div class={`flex max-w-3xl flex-col ${contentGapClass}`}>
    {
      breadcrumbs && (
        <Text
          size="label_2"
          weight="semibold"
          stylingclasses="text-(--neutral-400) tracking-widest uppercase"
        >
          {breadcrumbs}
        </Text>
      )
    }

    <Heading
      htmlheading="h1"
      size="h1"
      font="display"
      weight="bold"
      stylingclasses="text-[clamp(var(--heading-1-mobile),8vw,var(--heading-1-size))] leading-[1.05] text-(--neutral-500) [text-wrap:balance]"
    >
      <span class="block w-full" set:html={titleHtml} />
    </Heading>

    {
      subtitle && (
        <Text
          size="p1"
          stylingclasses={`text-(--neutral-500) ${subtitleClass}`}
        >
          {subtitle}
        </Text>
      )
    }

    {
      buttons.length > 0 && (
        <div class="mt-2 flex flex-wrap gap-3 md:mt-4 md:gap-4">
          {buttons.map((btn) => (
            <LinkButton
              href={btn.href}
              color={btn.color}
              label={btn.label}
              size={btn.size}
              stylingclasses={btn.stylingclasses}
              target={btn.target}
              rel={btn.rel}
            />
          ))}
        </div>
      )
    }
  </div>

  <!-- Image column — sits at bottom so figure "stands" on the section edge -->
  <div
    class={`flex items-end justify-center md:items-center md:justify-end ${imageWrapperClass}`}
  >
    <img
      src={imgSrc}
      alt={imageAlt}
      loading="eager"
      class:list={["h-auto w-full object-cover object-bottom", imageClass]}
    />
  </div>
</div>
