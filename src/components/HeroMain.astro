---
import Heading from "./Heading.astro";
import Text from "./Text.astro";
import LinkButton from "./Buttons__&_links/LinkButton.astro";

interface ButtonConfig {
  label: string;
  color: "main" | "primary" | "secondary" | "accent" | "neutral" | "outline";
  href: string;
}

interface Props {
  breadcrumbs?: string;
  // Titel må gerne indeholde HTML til linjeskift og farvede ord.
  titleHtml: string;
  subtitle?: string;
  imageSrc: string;
  imageAlt?: string;
  buttons?: ButtonConfig[];
}

const {
  breadcrumbs,
  titleHtml,
  subtitle,
  imageSrc,
  imageAlt = "Hero transparent billede",
  buttons = [],
} = Astro.props as Props;
---

<section
  class="relative w-full overflow-hidden bg-(--neutral-100) py-(--section-space-y)"
>
  <div
    class="relative z-10 flex w-full flex-col md:min-h-[clamp(31rem,70vw,42rem)] md:flex-row"
  >
    {
      /* Mobil først: tekst og billede ligger i normal flow, så intet bliver skåret af. */
    }
    <div
      class="z-20 flex w-full min-w-0 flex-col gap-[clamp(0.875rem,2vw,1.5rem)] px-[clamp(1rem,4vw,4rem)] pt-[clamp(1rem,2vw,2rem)] pb-[clamp(1rem,4vw,2.5rem)] md:w-[58%] md:px-[clamp(1.5rem,4vw,5rem)] md:pt-[clamp(2rem,4vw,4rem)] md:pb-(--section-space-y)"
    >
      {
        breadcrumbs && (
          <Text
            size="label_2"
            weight="semibold"
            stylingclasses="text-(--neutral-400) tracking-widest uppercase"
          >
            {breadcrumbs}
          </Text>
        )
      }

      <Heading
        htmlheading="h1"
        size="h1"
        font="display"
        weight="bold"
        stylingclasses="max-w-none break-words leading-[0.9] text-(--neutral-500)"
      >
        <span set:html={titleHtml} />
      </Heading>

      {
        subtitle && (
          <Text
            size="p1"
            weight="regular"
            stylingclasses="text-(--neutral-500)"
          >
            {subtitle}
          </Text>
        )
      }

      {
        buttons.length > 0 && (
          <div class="flex flex-wrap gap-3 pt-2 md:gap-4">
            {buttons.map((btn) => (
              <LinkButton href={btn.href} color={btn.color} label={btn.label} />
            ))}
          </div>
        )
      }
    </div>

    {
      /* Billedet ligger i flow på mobil og bliver først fastholdt i hjørnet fra md og op. */
    }
    <div
      class="pointer-events-none relative z-10 mt-[clamp(1rem,4vw,2rem)] flex w-full justify-end overflow-hidden px-[clamp(1rem,4vw,4rem)] md:absolute md:right-0 md:bottom-0 md:mt-0 md:h-full md:w-[42%] md:px-0 lg:w-[38%]"
    >
      <img
        src={imageSrc}
        alt={imageAlt}
        class="h-auto max-h-[clamp(20rem,70vw,32rem)] w-full max-w-[32rem] object-contain object-bottom-right md:max-h-[clamp(28rem,36vw,40rem)] md:max-w-none md:translate-y-[clamp(1rem,2vw,2rem)] lg:translate-x-[clamp(1rem,3vw,3rem)]"
      />
    </div>
  </div>
</section>
