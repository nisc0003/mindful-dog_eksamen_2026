---
/* =========================================================
  BUTTON.Astro
  Genbrugelig knap med styling til flere varianter
  ========================================================= */

type ButtonVariant =
  | "standard"
  | "search"
  | "dropdown"
  | "location"
  | "readmore"
  | "playpause"
  | "mute";

const sizeClasses = {
  sm: "h-[35px] px-4 text-size-14 rounded-sm gap-2",
  md: "h-[44px] px-5 text-size-15 rounded-md gap-2",
  lg: "h-[53px] px-6 text-size-17 rounded-md gap-3",
  xl: "h-[81px] px-8 text-size-30 rounded-md gap-3",
};

const iconSizeClasses = {
  sm: "size-[35px] rounded-sm",
  md: "size-[44px] rounded-md",
  lg: "size-[61px] rounded-md",
  xl: "size-[72px] rounded-md",
};

const colorClasses = {
  primary:
    "bg-(--button-primary-bg) text-(--button-primary-text) hover:bg-(--button-primary-bg-hover)",
  secondary:
    "bg-(--button-secondary-bg) text-(--button-secondary-text) hover:bg-(--button-secondary-bg-hover)",
  accent:
    "bg-(--button-accent-bg) text-(--button-accent-text) hover:bg-(--button-accent-bg-hover)",
  neutral:
    "bg-(--button-neutral-bg) text-(--button-neutral-text) hover:bg-(--button-neutral-bg-hover)",
  outline:
    "bg-transparent border border-(--button-outline-border) text-(--button-outline-text) hover:bg-(--button-outline-bg-hover)",
};

type ButtonSize = keyof typeof sizeClasses;
type ButtonColor = keyof typeof colorClasses;

interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  color?: ButtonColor;
  type?: "button" | "submit" | "reset";
  stylingclasses?: string;
  label?: string;
  placeholder?: string;
  options?: string[];
  dropdownTarget?: string;
  location?: string;
  fullText?: string;
  previewLength?: number;
  videoTarget?: string;
}

const {
  variant = "standard",
  size = "md",
  color = "primary",
  type = "button",
  stylingclasses = "",
  label = "",
  placeholder = "Søg…",
  options = [],
  dropdownTarget = "filter",
  location = "",
  fullText = "",
  previewLength = 120,
  videoTarget = "#demoVideo",
} = Astro.props as Props;

const baseBtn =
  "inline-flex items-center justify-center font-sans font-semibold leading-none transition-colors transition-transform duration-150 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus-visible:ring-2 focus-visible:ring-(--main-400) focus-visible:ring-offset-2 cursor-pointer";

const isIconOnly = variant === "playpause" || variant === "mute";
const cls = [
  baseBtn,
  isIconOnly ? iconSizeClasses[size] : sizeClasses[size],
  colorClasses[color],
  stylingclasses,
]
  .filter(Boolean)
  .join(" ");

const dropdownConfig = {
  target: dropdownTarget,
  label: label || "Vælg…",
  options,
};
---

{variant === "standard" && (
  <button type={type} class={cls}>
    <slot>{label}</slot>
  </button>
)}

{variant === "search" && (
  <form x-data="buttonSearch()" @submit.prevent="submit()" class="inline-flex items-stretch gap-0">
    <input
      type="search"
      x-model="query"
      placeholder={placeholder}
      class:list={[
        "border border-r-0 border-(--neutral-300) bg-(--neutral-0) px-3 text-(--neutral-500) outline-none focus:ring-2 focus:ring-(--main-400)",
        sizeClasses[size],
        "rounded-l-md rounded-r-none",
      ]}
    />

    <button type="submit" class:list={[cls, "rounded-l-none rounded-r-md"]}>
      <img src="https://placehold.co/24x24" alt="Søg" class="size-4" />
      <span>{label || "Søg"}</span>
    </button>
  </form>
)}

{variant === "dropdown" && (
  <div x-data={`buttonDropdown(${JSON.stringify(dropdownConfig)})`} class="relative inline-block">
    <button type="button" @click="toggle()" @click.outside="close()" class={cls}>
      <span x-text="currentLabel()"></span>

      <img
        src="https://placehold.co/24x24"
        alt="Dropdown"
        class="size-4 transition-transform"
        :class="open && 'rotate-180'"
      />
    </button>

    <ul
      x-show="open"
      x-transition
      x-cloak
      class="absolute z-10 mt-1 min-w-50 overflow-hidden rounded-md border border-(--neutral-200) bg-(--neutral-0) shadow-lg"
    >
      <li>
        <button type="button" @click="select('')" class="block w-full px-4 py-2 text-left hover:bg-(--neutral-200)">
          Alle
        </button>
      </li>

      {options.map((option) => (
        <li>
          <button type="button" @click={`select(${JSON.stringify(option)})`} class="block w-full px-4 py-2 text-left hover:bg-(--neutral-200)">
            {option}
          </button>
        </li>
      ))}
    </ul>
  </div>
)}

{variant === "location" && (
  <button
    x-data={`buttonLocation(${JSON.stringify(location)})`}
    type="button"
    @click="toggle()"
    :class="active && 'ring-2 ring-(--main-500)'"
    class={cls}
  >
    <img src="https://placehold.co/24x24" alt="Lokation" class="size-4" />
    <span>{label || location}</span>
  </button>
)}

{variant === "readmore" && (
  <div x-data={`buttonReadmore(${JSON.stringify(fullText)}, ${previewLength})`} class="max-w-prose">
    <p class="mb-3 text-size-15">
      <span x-text="open ? fullText : previewText"></span>
    </p>

    <button type="button" @click="toggle()" class={cls}>
      <span x-text="open ? 'Læs mindre' : 'Læs mere'"></span>
    </button>
  </div>
)}

{variant === "playpause" && (
  <button x-data={`buttonPlayPause(${JSON.stringify(videoTarget)})`} type="button" @click="toggle()" aria-label="Afspil/pause" class={cls}>
    <img src="https://placehold.co/24x24" x-show="!playing" class="size-1/2" />
    <img src="https://placehold.co/24x24" x-show="playing" class="size-1/2" />
  </button>
)}

{variant === "mute" && (
  <button x-data={`buttonMute(${JSON.stringify(videoTarget)})`} type="button" @click="toggle()" aria-label="Mute/unmute" class={cls}>
    <img src="https://placehold.co/24x24" x-show="muted" class="size-1/2" />
    <img src="https://placehold.co/24x24" x-show="!muted" class="size-1/2" />
  </button>
)}

