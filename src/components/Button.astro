---
/* =========================================================
   BUTTON.Astro
   Reusable button component med mange variants
   ========================================================= */

/* =========================
   Størrelser og layout
   Definerer padding, height og tekststørrelse pr. size
   ========================= */
const sizeClasses = {
  sm: "h-[35px] px-4 text-size-14 rounded-sm gap-2",
  md: "h-[44px] px-5 text-size-15 rounded-md gap-2",
  lg: "h-[53px] px-6 text-size-17 rounded-md gap-3",
  xl: "h-[81px] px-8 text-size-30 rounded-md gap-3",
};

/* =========================
   Ikon-knap størrelser
   Bruges kun til play/mute icons (square buttons)
   ========================= */
const iconSizeClasses = {
  sm: "size-[35px] rounded-sm",
  md: "size-[44px] rounded-md",
  lg: "size-[61px] rounded-md",
  xl: "size-[72px] rounded-md",
};

/* =========================
   Farvetokens (design system)
   Alle farver kommer fra CSS variables
   ========================= */
const colorClasses = {
  primary:
    "bg-(--button-primary-bg) text-(--button-primary-text) hover:bg-(--button-primary-bg-hover)",
  secondary:
    "bg-(--button-secondary-bg) text-(--button-secondary-text) hover:bg-(--button-secondary-bg-hover)",
  accent:
    "bg-(--button-accent-bg) text-(--button-accent-text) hover:bg-(--button-accent-bg-hover)",
  neutral:
    "bg-(--button-neutral-bg) text-(--button-neutral-text) hover:bg-(--button-neutral-bg-hover)",
  outline:
    "bg-transparent border border-(--button-outline-border) text-(--button-outline-text) hover:bg-(--button-outline-bg-hover)",
};

/* =========================
   Type definition for variants
   ========================= */
type ButtonVariant =
  | "standard"
  | "search"
  | "dropdown"
  | "location"
  | "readmore"
  | "playpause"
  | "mute";

/* =========================
   Props typer
   ========================= */
type ButtonSize = keyof typeof sizeClasses;
type ButtonColor = keyof typeof colorClasses;

/* =========================
   Props interface
   Definerer alle input-muligheder til komponenten
   ========================= */
interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  color?: ButtonColor;
  type?: "button" | "submit" | "reset";
  stylingclasses?: string;

  /* Standard button label */
  label?: string;

  /* Search input placeholder */
  placeholder?: string;

  /* Dropdown options */
  options?: string[];

  /* Target key i Alpine store */
  dropdownTarget?: string;

  /* Location filter value */
  location?: string;

  /* Read more content */
  fullText?: string;
  previewLength?: number;

  /* Video target selector */
  videoTarget?: string;
}

/* =========================
   Default props
   ========================= */
const {
  variant = "standard",
  size = "md",
  color = "primary",
  type = "button",
  stylingclasses = "",
  label = "",
  placeholder = "Søg…",
  options = [],
  dropdownTarget = "filter",
  location = "",
  fullText = "",
  previewLength = 120,
  videoTarget = "#demoVideo",
} = Astro.props as Props;

/* =========================
   Base styling (shared)
   bruges af alle buttons
   ========================= */
const baseBtn =
  "inline-flex items-center justify-center font-sans font-semibold leading-none transition-colors transition-transform duration-150 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus-visible:ring-2 focus-visible:ring-(--main-400) focus-visible:ring-offset-2 cursor-pointer";

/* =========================
   Ikon-only detection
   ========================= */
const isIconOnly =
  variant === "playpause" || variant === "mute";

/* =========================
   Vælg korrekt sizing system
   ========================= */
const sizing = isIconOnly
  ? iconSizeClasses[size]
  : sizeClasses[size];

/* =========================
   Final class string
   ========================= */
const cls = [baseBtn, sizing, colorClasses[color], stylingclasses]
  .filter(Boolean)
  .join(" ");
---

<!-- =========================================================
     STANDARD BUTTON
     ========================================================= -->
{variant === "standard" && (
  <button type={type} class={cls}>
    <slot>{label}</slot>
  </button>
)}

<!-- =========================================================
     SEARCH BUTTON + INPUT
     ========================================================= -->
{variant === "search" && (
  <form
    x-data={`{ q: '' }`} /* Alpine state for search query */
    @submit.prevent={`alert('Søger efter: ' + q)`} /* demo submit */
    class="inline-flex items-stretch gap-0"
  >
    {/* Search input field */}
    <input
      type="search"
      x-model="q"
      placeholder={placeholder}
      class:list={[
        "border border-r-0 border-(--neutral-300) bg-(--neutral-0) text-(--neutral-500) px-3 outline-none focus:ring-2 focus:ring-(--main-400)",
        sizeClasses[size],
        "rounded-l-md rounded-r-none",
      ]}
    />

    {/* Submit button */}
    <button
      type="submit"
      class:list={[cls, "rounded-l-none rounded-r-md"]}
    >
      <img src="https://placehold.co/24x24" alt="Søg" class="size-4" />
      <span>{label || "Søg"}</span>
    </button>
  </form>
)}

<!-- =========================================================
     DROPDOWN BUTTON
     ========================================================= -->
{variant === "dropdown" && (
  <div x-data="{ open: false }" class="relative inline-block">
    {/* Toggle button */}
    <button
      type="button"
      @click="open = !open"
      @click.outside="open = false"
      class={cls}
    >
      {/* Current selection */}
      <span x-text={`$store.filters.${dropdownTarget} || '${label || "Vælg…"}'`}></span>

      {/* Arrow icon */}
      <img
        src="https://placehold.co/24x24"
        alt="Dropdown"
        class="size-4 transition-transform"
        :class="open && 'rotate-180'"
      />
    </button>

    {/* Dropdown menu */}
    <ul
      x-show="open"
      x-transition
      x-cloak
      class="absolute z-10 mt-1 min-w-50 bg-(--neutral-0) border border-(--neutral-200) rounded-md shadow-lg overflow-hidden"
    >
      {/* Reset option */}
      <li>
        <button
          type="button"
          @click={`$store.filters.${dropdownTarget} = ''; open = false`}
          class="block w-full text-left px-4 py-2 hover:bg-(--neutral-200)"
        >
          Alle
        </button>
      </li>

      {/* Dynamic options */}
      {options.map((opt) => (
        <li>
          <button
            type="button"
            @click={`$store.filters.${dropdownTarget} = '${opt}'; open = false`}
            class="block w-full text-left px-4 py-2 hover:bg-(--neutral-200)"
          >
            {opt}
          </button>
        </li>
      ))}
    </ul>
  </div>
)}

<!-- =========================================================
     LOCATION FILTER BUTTON
     ========================================================= -->
{variant === "location" && (
  <button
    type="button"
    @click={`$store.filters.location = ($store.filters.location === '${location}' ? '' : '${location}')`}
    :class={`$store.filters.location === '${location}' && 'ring-2 ring-(--main-500)'`}
    class={cls}
  >
    <img src="https://placehold.co/24x24" alt="Lokation" class="size-4" />
    <span>{label || location}</span>
  </button>
)}

<!-- =========================================================
     READ MORE / LESS
     ========================================================= -->
{variant === "readmore" && (
  <div
    x-data={`{
      open: false,
      full: ${JSON.stringify(fullText)},
      preview: ${JSON.stringify(
        fullText.slice(0, previewLength) +
        (fullText.length > previewLength ? "…" : "")
      )}
    }`}
    class="max-w-prose"
  >
    {/* Text preview / full */}
    <p class="text-size-15 mb-3">
      <span x-text="open ? full : preview"></span>
    </p>

    {/* Toggle button */}
    <button type="button" @click="open = !open" class={cls}>
      <span x-text="open ? 'Læs mindre' : 'Læs mere'"></span>
    </button>
  </div>
)}

<!-- =========================================================
     PLAY / PAUSE VIDEO BUTTON
     ========================================================= -->
{variant === "playpause" && (
  <button
    type="button"
    x-data={`{
      playing: false,
      toggle() {
        const v = document.querySelector('${videoTarget}');
        if (!v) return;
        if (v.paused) { v.play(); this.playing = true; }
        else { v.pause(); this.playing = false; }
      }
    }`}
    @click="toggle()"
    aria-label="Afspil/pause"
    class={cls}
  >
    {/* Play icon */}
    <img
      src="https://placehold.co/24x24"
      x-show="!playing"
      class="size-1/2"
    />

    {/* Pause icon */}
    <img
      src="https://placehold.co/24x24"
      x-show="playing"
      class="size-1/2"
    />
  </button>
)}

<!-- =========================================================
     MUTE BUTTON
     ========================================================= -->
{variant === "mute" && (
  <button
    type="button"
    x-data={`{
      muted: true,
      toggle() {
        const v = document.querySelector('${videoTarget}');
        if (!v) return;
        v.muted = !v.muted;
        this.muted = v.muted;
      }
    }`}
    @click="toggle()"
    aria-label="Mute/unmute"
    class={cls}
  >
    {/* Muted icon */}
    <img
      src="https://placehold.co/24x24"
      x-show="muted"
      class="size-1/2"
    />

    {/* Sound icon */}
    <img
      src="https://placehold.co/24x24"
      x-show="!muted"
      class="size-1/2"
    />
  </button>
)}