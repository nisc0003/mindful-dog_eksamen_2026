---
/* =========================================================
   LÆS MERE (SIMPLE TEXT LINK VERSION)
   ========================================================= */

import Text from "../Text.astro";

interface Props {
  fullText: string;
  previewLength?: number;
  stylingclasses?: string;
}

const {
  fullText,
  previewLength = 140,
  stylingclasses = "",
} = Astro.props as Props;

// Den korte tekst vises først, og knappen skifter mellem kort og fuld version.
const previewText =
  fullText.length > previewLength
    ? `${fullText.slice(0, previewLength)}…`
    : fullText;
---

<div
  x-data={`{
    open: false,
    fullText: ${JSON.stringify(fullText)},
    previewText: ${JSON.stringify(previewText)},
    toggle() {
      this.open = !this.open;
    }
  }`}
  class={["max-w-prose", stylingclasses].filter(Boolean).join(" ")}
>
  <Text size="p3" font="sans" weight="regular" stylingclasses="leading-relaxed">
    <span x-text="open ? fullText : previewText"></span>
    <button
      type="button"
      @click="toggle()"
      class="ml-1 inline cursor-pointer font-sans text-(--link-text) underline decoration-1 underline-offset-2 transition-opacity hover:opacity-70"
    >
      <span x-text="open ? 'Læs mindre' : 'Læs mere'"></span>
    </button>
  </Text>
</div>
