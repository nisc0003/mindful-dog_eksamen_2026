---
/* =========================================================
   SØGEKNAP
   sm/md  → ikon-knap, klik åbner søgefeltet
   lg/xl  → altid åben
   ========================================================= */

type Size = "sm" | "md" | "lg" | "xl";

interface Props {
  size?:           Size;
  placeholder?:    string;
  label?:          string;
  stylingclasses?: string;
}

const {
  size           = "md",
  placeholder    = "Søg her…",
  label          = "Søg",
  stylingclasses = "",
} = Astro.props as Props;

const collapsible = size === "sm" || size === "md";

const s = {
  sm: { h: "h-[35px]", r: "rounded-sm", text: "text-[13px]", px: "px-3", btnPx: "px-4", icon: 14, gap: "gap-1.5" },
  md: { h: "h-[44px]", r: "rounded-md", text: "text-[14px]", px: "px-4", btnPx: "px-5", icon: 15, gap: "gap-2"   },
  lg: { h: "h-[53px]", r: "rounded-md", text: "text-[15px]", px: "px-4", btnPx: "px-5", icon: 17, gap: "gap-2"   },
  xl: { h: "h-[81px]", r: "rounded-md", text: "text-[20px]", px: "px-5", btnPx: "px-7", icon: 22, gap: "gap-3"   },
}[size];
---

{collapsible ? (
  <div
    x-data="{ open: false, query: '' }"
    x-on:keydown.escape.window="open = false"
    x-on:click.outside="open = false"
    class:list={["inline-flex", stylingclasses]}
  >

    <!-- Lukket: ikon-knap -->
    <button
      x-show="!open"
      x-on:click="open = true; $nextTick(() => $refs.input.focus())"
      type="button"
      aria-label="Åbn søgefelt"
      class:list={["inline-flex aspect-square items-center justify-center bg-(--neutral-0) border border-(--neutral-200) text-(--neutral-400) shadow-xs transition hover:border-(--neutral-300) hover:text-(--neutral-500) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--main-400) focus-visible:ring-offset-1 cursor-pointer", s.h, s.r]}
    >
      <svg width={s.icon} height={s.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
      </svg>
    </button>

    <!-- Åben: søgefelt -->
    <form
      x-show="open"
      x-on:submit.prevent="$dispatch('search', { query })"
      class:list={["inline-flex items-stretch overflow-hidden border border-(--neutral-200) bg-(--neutral-0) shadow-xs focus-within:border-(--main-400) focus-within:ring-2 focus-within:ring-(--main-400)/20 transition-all", s.h, s.r, s.text]}
      style="display:none;"
    >
      <span class="flex shrink-0 items-center pl-3 text-(--neutral-300)">
        <svg width={s.icon} height={s.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
      </span>

      <input
        x-ref="input"
        x-model="query"
        type="search"
        placeholder={placeholder}
        class:list={["w-[160px] bg-transparent outline-none text-(--neutral-500) placeholder:text-(--neutral-300) font-[Manrope,sans-serif]", s.px]}
      />

      <button
        type="submit"
        class:list={["shrink-0 inline-flex items-center font-[Manrope,sans-serif] font-semibold bg-(--main-400) text-white transition-colors hover:bg-(--main-500) cursor-pointer", s.btnPx, s.gap]}
      >
        <svg width={s.icon} height={s.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
        {label}
      </button>
    </form>

  </div>
) : (
  /* lg / xl — altid åben */
  <form
    x-data="{ query: '' }"
    x-on:submit.prevent="$dispatch('search', { query })"
    class:list={["inline-flex items-stretch overflow-hidden border border-(--neutral-200) bg-(--neutral-0) shadow-xs focus-within:border-(--main-400) focus-within:ring-2 focus-within:ring-(--main-400)/20 transition-all", s.h, s.r, s.text, stylingclasses]}
  >
    <span class="flex shrink-0 items-center pl-4 text-(--neutral-300)">
      <img src="https://placehold.co/24x24" alt="Søg" class="size-4" />
    </span>

    <input
      x-model="query"
      type="search"
      placeholder={placeholder}
      class:list={["min-w-[200px] flex-1 bg-transparent outline-none text-(--neutral-500) placeholder:text-(--neutral-300) font-[Manrope,sans-serif]", s.px]}
    />

    <button
      type="submit"
      class:list={["shrink-0 inline-flex items-center font-[Manrope,sans-serif] font-semibold bg-(--main-400) text-white transition-colors hover:bg-(--main-500) cursor-pointer", s.btnPx, s.gap]}
    >
      <img src="https://placehold.co/24x24" alt="Søg" class="size-4" />
      {label}
    </button>
  </form>
)}