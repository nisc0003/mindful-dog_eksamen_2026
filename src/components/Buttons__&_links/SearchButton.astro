---
/* =========================================================
   SØGEKNAP
  Små størrelser åbner et søgefelt, mens store størrelser vises åbent.
   ========================================================= */

type Size = "sm" | "md" | "lg" | "xl";

interface Props {
  size?:           Size;
  placeholder?:    string;
  label?:          string;
  stylingclasses?: string;
}

const {
  size           = "md",
  placeholder    = "Søg her…",
  label          = "Søg",
  stylingclasses = "",
} = Astro.props as Props;

// Små størrelser starter som en lukket knap, store størrelser viser feltet direkte.
const collapsible = size === "sm" || size === "md";

// Ensartet ikon-pladsholder, så komponenten ikke bruger inline SVG.
const iconSrc = "https://placehold.co/24x24";

const s = {
  sm: {
    h: "h-[35px]",
    r: "rounded-sm",
    text: "text-size-14",
    px: "px-3",
    btnPx: "px-4",
    icon: "size-4",
    gap: "gap-1.5",
  },
  md: {
    h: "h-[44px]",
    r: "rounded-md",
    text: "text-size-15",
    px: "px-4",
    btnPx: "px-5",
    icon: "size-4",
    gap: "gap-2",
  },
  lg: {
    h: "h-[53px]",
    r: "rounded-md",
    text: "text-size-17",
    px: "px-4",
    btnPx: "px-5",
    icon: "size-4",
    gap: "gap-2",
  },
  xl: {
    h: "h-[81px]",
    r: "rounded-md",
    text: "text-size-20",
    px: "px-5",
    btnPx: "px-7",
    icon: "size-5",
    gap: "gap-3",
  },
}[size];
---

{collapsible ? (
  <div
    x-data="{ open: false, query: '' }"
    x-on:keydown.escape.window="open = false"
    x-on:click.outside="open = false"
    class:list={["inline-flex", stylingclasses]}
  >

    <!-- Lukket tilstand: en tydelig søgeknap med ikon og tekst. -->
    <button
      x-show="!open"
      x-on:click="open = true; $nextTick(() => $refs.input.focus())"
      type="button"
      aria-label="Åbn søgefelt"
      class:list={["inline-flex items-center justify-center border border-(--neutral-200) bg-(--neutral-0) font-sans font-semibold text-(--neutral-500) shadow-xs transition hover:border-(--neutral-300) hover:bg-(--neutral-100) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--main-400) focus-visible:ring-offset-1 cursor-pointer", s.h, s.r, s.text, s.gap, s.btnPx]}
    >
      <img src={iconSrc} alt="Søg" class={s.icon} />
    </button>

    <!-- Åben tilstand: felt til tekst, efterfulgt af en egentlig submit-knap. -->
    <form
      x-show="open"
      x-on:submit.prevent="$dispatch('search', { query })"
      class:list={["inline-flex items-stretch overflow-hidden border border-(--neutral-200) bg-(--neutral-0) shadow-xs transition-all focus-within:border-(--main-400) focus-within:ring-2 focus-within:ring-(--main-400)/20", s.h, s.r, s.text]}
      style="display:none;"
    >

      <input
        x-ref="input"
        x-model="query"
        type="search"
        placeholder={placeholder}
        class:list={["w-40 bg-transparent font-sans text-(--neutral-500) outline-none placeholder:text-(--neutral-300)", s.px]}
      />

      <button
        type="submit"
        class:list={["shrink-0 inline-flex items-center font-sans font-semibold bg-(--main-400) text-white transition-colors hover:bg-(--main-500) cursor-pointer", s.btnPx, s.gap]}
      >
        <img src={iconSrc} alt="Søg" class={s.icon} />
        {label}
      </button>
    </form>

  </div>
) : (
  /* Store størrelser: søgefeltet er åbent fra start. */
  <form
    x-data="{ query: '' }"
    x-on:submit.prevent="$dispatch('search', { query })"
    class:list={["inline-flex items-stretch overflow-hidden border border-(--neutral-200) bg-(--neutral-0) shadow-xs transition-all focus-within:border-(--main-400) focus-within:ring-2 focus-within:ring-(--main-400)/20", s.h, s.r, s.text, stylingclasses]}
  >
    <input
      x-model="query"
      type="search"
      placeholder={placeholder}
      class:list={["min-w-50 flex-1 bg-transparent font-sans text-(--neutral-500) outline-none placeholder:text-(--neutral-300)", s.px]}
    />

    <button
      type="submit"
      class:list={["shrink-0 inline-flex items-center font-sans font-semibold bg-(--main-400) text-white transition-colors hover:bg-(--main-500) cursor-pointer", s.btnPx, s.gap]}
    >
      <img src={iconSrc} alt="Søg" class={s.icon} />
      {label}
    </button>
  </form>
)}