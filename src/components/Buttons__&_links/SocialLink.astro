---
/* ========================================================= 
SOCIAL LINK
========================================================= */

type SocialIcon = {
  src: string;
  width: number;
  height: number;
};

type SocialLinkSize = "sm" | "md" | "lg";

interface Props {
  size?: SocialLinkSize;
  href?: string;
  iconSrc: SocialIcon | string;
  iconAlt?: string;
}

const {
  size = "md",
  href = "#",
  iconSrc,
  iconAlt = "Social Link",
} = Astro.props as Props;

const sizeClasses = {
  sm: "w-12 h-12",
  md: "w-16 h-16",
  lg: "w-20 h-20",
};

const imgSrc = typeof iconSrc === "string" ? iconSrc : iconSrc.src;
const imgWidth = typeof iconSrc === "string" ? undefined : iconSrc.width;
const imgHeight = typeof iconSrc === "string" ? undefined : iconSrc.height;
---

<a
  href={href}
  aria-label={iconAlt}
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center justify-center transition-transform hover:scale-105"
>
  <img
    src={imgSrc}
    alt={iconAlt}
    width={imgWidth}
    height={imgHeight}
    class={`block ${sizeClasses[size]}`}
  />
</a>
