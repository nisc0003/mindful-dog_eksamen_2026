---
// Tekstkomponenten samler alle brødtekst- og label-varianter på ét sted.
const sizeClasses = {
  p1: "text-size-20 md:text-size-20 lg:text-size-25 xl:text-size-28 2xl:text-size-30",
  p2: "text-size-16 md:text-size-17 lg:text-size-20 xl:text-size-20 2xl:text-size-22",
  p3: "text-size-15 md:text-size-16 lg:text-size-16 xl:text-size-17 2xl:text-size-18",
  p4: "text-size-10 md:text-size-12 lg:text-size-14 xl:text-size-15 2xl:text-size-16",

  label_1:
    "text-size-14 md:text-size-16 lg:text-size-17 xl:text-size-20 2xl:text-size-20 uppercase",

  label_2:
    "text-size-10 md:text-size-12 lg:text-size-13 xl:text-size-14 2xl:text-size-15",
};

const fontClasses = {
  display: "font-display",
  sans: "font-sans",
};

const weightClasses = {
  bold: "font-bold",
  semibold: "font-semibold",
  regular: "font-normal",
  light: "font-light",
};

type TextSize = keyof typeof sizeClasses;
type TextFont = keyof typeof fontClasses;
type TextWeight = keyof typeof weightClasses;

interface Props {
  font?: TextFont;
  weight?: TextWeight;
  size?: TextSize;
  stylingclasses?: string;
}

const {
  font = "sans",
  weight = "regular",
  size = "p2",
  stylingclasses = "",
  ...rest
} = Astro.props as Props;
---

<p
  {...rest}
  class:list={[
    stylingclasses,
    sizeClasses[size],
    fontClasses[font],
    weightClasses[weight],
  ]}
>
  <slot />
</p>
