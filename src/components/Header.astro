---
import Logo from "../assets/icon/snudeLogo.webp";
import { Image } from "astro:assets";
---

<header class="sticky top-0 z-10 bg-(--primitive-neutral-100)">
  <nav
    class="m-auto mt-0 mb-8 flex w-[100cqw] items-center justify-between gap-4 p-4 text-center font-bold"
  >
    <div class="w-[16.5cqw]">
      <a href="/"><Image src={Logo} alt="Logo" class="h-auto w-18" /></a>
    </div>
    <ul
      class="menu first hidden list-none sm:flex sm:justify-between sm:gap-8 [&_li]:relative [&_li]:block [&_li]:text-2xl [&_li]:text-(--primitive-neutral-500) [&_li]:no-underline [&_li]:transition-colors [&_li]:duration-150 [&_li]:hover:text-(--primitive-accent-200) [&_li]:sm:mx-auto [&_li]:sm:text-sm [&_li]:md:text-lg [&_li]:lg:text-2xl"
    >
      <li>
        <a href="/">FORSIDE</a>
      </li>
      <li>
        <a href="/Hold_oversigt">HOLD OVERSIGT</a>
      </li>
      <li>
        <a href="/Om_os">OM OS</a>
      </li>
      <li>
        <a href="/">BLOG</a>
      </li>
    </ul>
    <a
      href="/Bliv_instruktoer"
      class="menu second hidden text-2xl no-underline sm:block sm:text-right sm:text-sm md:text-lg lg:text-2xl"
      >BLIV INSTRUKTØR</a
    >
    <div
      id="burger"
      class="rounded-5 relative z-10 mr-2 h-10 w-10 cursor-pointer sm:hidden [&_span]:relative [&_span]:my-1.5 [&_span]:block [&_span]:h-1.5 [&_span]:w-full [&_span]:rounded-sm [&_span]:bg-neutral-900"
    >
      <span></span>
      <span></span>
      <span></span>
    </div>
  </nav>
</header>

<style>
  span {
    transition:
      transform 0.5s cubic-bezier(0.77, 0.2, 0.05, 1),
      opacity 0.55s ease;
  }

  nav > #burger.active span:nth-child(1) {
    transform: rotate(45deg) translate(0, -2px);
  }

  nav > #burger span:nth-child(1) {
    transform-origin: 0% 0%;
  }
  nav > #burger.active span:nth-child(2) {
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  nav > #burger span:nth-child(2) {
    opacity: 1;
    transition: opacity 0.55s ease-in;
  }

  nav > #burger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(0, 2px);
  }
  nav > #burger span:nth-child(3) {
    transform-origin: 0% 100%;
  }

  nav.active .menu.first {
    display: block;
    position: absolute;
    background-color: var(--primitive-neutral-100);
    top: calc(var(--spacing) * 21);
    right: 0;
    width: 100%;
    z-index: 1;
    text-align: right;
    padding-right: calc(var(--spacing) * 4);
  }

  nav.active .menu.second {
    display: block;
    position: absolute;
    background-color: var(--primitive-neutral-100);
    top: calc(var(--spacing) * 53);
    right: 0;
    width: 100%;
    z-index: 1;
    text-align: right;
    padding-right: calc(var(--spacing) * 4);
  }
</style>

<script src="../assets/js/burger.js"></script>
