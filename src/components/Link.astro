---
/* =========================================================
   LINK.Astro
   Reusable link component (button + social + breadcrumb)
   ========================================================= */

/* =========================
   Button-like link sizes
   ========================= */
const sizeClasses = {
  xs: "h-[28px] px-3 text-(length:--text-size-10) rounded-sm gap-1",
  sm: "h-[35px] px-4 text-size-14 rounded-sm gap-2",
  md: "h-[44px] px-5 text-size-15 rounded-md gap-2",
  lg: "h-[53px] px-6 text-size-17 rounded-md gap-3",
  xl: "h-[81px] px-8 text-size-30 rounded-md gap-3",
};

/* =========================
   Social icon sizes
   ========================= */
const socialSizeClasses = {
  xs: "size-[24px]",
  sm: "size-[32px]",
  md: "size-[44px]",
  lg: "size-[56px]",
  xl: "size-[72px]",
};

/* =========================
   Color tokens
   ========================= */
const colorClasses = {
  primary:
    "bg-(--button-primary-bg) text-(--button-primary-text) hover:bg-(--button-primary-bg-hover)",
  secondary:
    "bg-(--button-secondary-bg) text-(--button-secondary-text) hover:bg-(--button-secondary-bg-hover)",
  accent:
    "bg-(--button-accent-bg) text-(--button-accent-text) hover:bg-(--button-accent-bg-hover)",
  neutral:
    "bg-(--button-neutral-bg) text-(--button-neutral-text) hover:bg-(--button-neutral-bg-hover)",
  outline:
    "bg-transparent border border-(--button-outline-border) text-(--button-outline-text) hover:bg-(--button-outline-bg-hover)",
};

/* =========================
   Types
   ========================= */
type LinkVariant = "standard" | "social" | "crawl";
type LinkSize = keyof typeof sizeClasses;
type LinkColor = keyof typeof colorClasses;
type SocialNetwork = "facebook" | "x" | "instagram";

/* =========================
   Props interface
   ========================= */
interface Props {
  variant?: LinkVariant;
  size?: LinkSize;
  color?: LinkColor;
  href?: string;
  label?: string;
  stylingclasses?: string;

  /* Social icon type */
  network?: SocialNetwork;

  /* Breadcrumb trail */
  trail?: { label: string; href?: string; filter?: string }[];
}

/* =========================
   Default props
   ========================= */
const {
  variant = "standard",
  size = "md",
  color = "primary",
  href = "#",
  label = "",
  stylingclasses = "",
  network = "facebook",
  trail = [],
} = Astro.props as Props;

/* =========================
   Base link styling
   ========================= */
const baseLink =
  "inline-flex items-center justify-center font-sans font-semibold leading-none transition-colors transition-transform duration-150 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus-visible:ring-2 focus-visible:ring-(--main-400) focus-visible:ring-offset-2 no-underline cursor-pointer";

/* =========================
   Standard link styles
   ========================= */
const stdClass = [
  baseLink,
  sizeClasses[size],
  colorClasses[color],
  stylingclasses,
]
  .filter(Boolean)
  .join(" ");

/* =========================
   Social link styles
   ========================= */
const socialClass = [
  baseLink,
  socialSizeClasses[size],
  "rounded-full",
  colorClasses[color],
  stylingclasses,
]
  .filter(Boolean)
  .join(" ");
---

<!-- =========================================================
     STANDARD LINK
     ========================================================= -->{
  variant === "standard" && (
    <a href={href} class={stdClass}>
      <slot>{label}</slot>
    </a>
  )
}

<!-- =========================================================
     SOCIAL ICON LINK
     ========================================================= -->
{
  variant === "social" && (
    <a
      href={href}
      aria-label={network}
      class={socialClass}
      target="_blank"
      rel="noopener"
    >
      {/* Facebook icon */}
      {network === "facebook" && (
        <img src="https://placehold.co/32x32" alt="Facebook" class="size-1/2" />
      )}

      {/* X icon */}
      {network === "x" && (
        <img src="https://placehold.co/32x32" alt="X" class="size-1/2" />
      )}

      {/* Instagram icon */}
      {network === "instagram" && (
        <img
          src="https://placehold.co/32x32"
          alt="Instagram"
          class="size-1/2"
        />
      )}
    </a>
  )
}

<!-- =========================================================
     BREADCRUMB / CRAWL NAV
     ========================================================= -->
{
  variant === "crawl" && (
    <nav aria-label="Breadcrumb" class="text-size-15 text-(--neutral-400)">
      <ol class="flex flex-wrap items-center gap-2">
        {/* Loop breadcrumb steps */}
        {trail.map((step, i) => (
          <li class="flex items-center gap-2">
            {/* Filter step (updates store) */}
            {step.filter ? (
              <button
                type="button"
                @click={`$store.filters.category = '${step.filter}'`}
                class="hover:text-(--link-text-hover) hover:underline"
              >
                {step.label}
              </button>
            ) : (
              /* Normal link step */
              <a
                href={step.href || "#"}
                class="hover:text-(--link-text-hover) hover:underline"
              >
                {step.label}
              </a>
            )}

            {/* Separator arrow */}
            {i < trail.length - 1 && <span aria-hidden="true">›</span>}
          </li>
        ))}
      </ol>
    </nav>
  )
}
