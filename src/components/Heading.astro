---
// Overskriftskomponenten samler alle heading-størrelser og font-variationer.
const sizeClasses = {
  h1: "text-size-65 md:text-size-80 lg:text-size-100 xl:text-size-140 2xl:text-size-180 leading-(--text-size-65) md:leading-(--text-size-80) lg:leading-(--text-size-100) xl:leading-(--text-size-140) 2xl:leading-(--text-size-180)",
  h2: "text-size-40 md:text-size-65 lg:text-size-80 xl:text-size-90 2xl:text-size-100 leading-(--text-size-40) md:leading-(--text-size-65) lg:leading-(--text-size-80) xl:leading-(--text-size-90) 2xl:leading-(--text-size-100)",
  h3: "text-size-25 md:text-size-40 lg:text-size-65 xl:text-size-72 2xl:text-size-80 leading-(--text-size-30) md:leading-(--text-size-42) lg:leading-(--text-size-65) xl:leading-(--text-size-72) 2xl:leading-(--text-size-80)",
  h4: "text-size-25 md:text-size-30 lg:text-size-30 xl:text-size-36 2xl:text-size-40 leading-(--text-size-30) md:leading-(--text-size-36) lg:leading-(--text-size-36) xl:leading-(--text-size-40) 2xl:leading-(--text-size-42)",
  h5: "text-size-20 md:text-size-25 lg:text-size-25 xl:text-size-28 2xl:text-size-30 leading-(--text-size-25) md:leading-(--text-size-30) lg:leading-(--text-size-30) xl:leading-(--text-size-34) 2xl:leading-(--text-size-36)",
  h6: "text-size-15 md:text-size-16 lg:text-size-17 xl:text-size-18 2xl:text-size-20 leading-(--text-size-18) md:leading-(--text-size-20) lg:leading-(--text-size-22) xl:leading-(--text-size-25) 2xl:leading-(--textsize-25)",
};
const fontClasses = {
  display: "font-display",
  sans: "font-sans",
};

const weightClasses = {
  bold: "font-bold",
  semibold: "font-semibold",
  regular: "font-normal",
  light: "font-light",
};

type HeadingSize = keyof typeof sizeClasses;
type HeadingFont = keyof typeof fontClasses;
type HeadingWeight = keyof typeof weightClasses;

interface Props {
  htmlheading?: string;
  size?: HeadingSize;
  font?: HeadingFont;
  weight?: HeadingWeight;
  stylingclasses?: string;
}

const {
  htmlheading = "h2",
  size = "h2",
  font = "sans",
  weight = "regular",
  stylingclasses = "",
  ...rest
} = Astro.props as Props;
const Htmlheading = htmlheading;
---

<Htmlheading
  {...rest}
  class:list={[
    stylingclasses,
    sizeClasses[size],
    fontClasses[font],
    weightClasses[weight],
  ]}><slot /></Htmlheading
>
