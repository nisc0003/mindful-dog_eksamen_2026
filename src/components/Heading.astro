---
// Overskriftskomponenten samler alle heading-størrelser og font-variationer.
const sizeClasses = {
  h1: "text-size-65 md:text-size-80 lg:text-size-100 xl:text-size-180",
  h2: "text-size-40 md:text-size-65 lg:text-size-80 xl:text-size-100",
  h3: "text-size-25 md:text-size-40 lg:text-size-65 xl:text-size-80",
  h4: "text-size-25 md:text-size-30 lg:text-size-30 xl:text-size-40",
  h5: "text-size-20 md:text-size-25 lg:text-size-25 xl:text-size-30",
  h6: "text-size-15 md:text-size-16 lg:text-size-17 xl:text-size-20",
};

// Font-valget peger på de skrifttyper, der er defineret i tailwind.css.
const fontClasses = {
  display: "font-display",
  sans: "font-sans",
};

// Vægtklasserne bruges til at vise, hvordan typografien ændrer sig i biblioteket.
const weightClasses = {
  bold: "text-bold",
  regular: "text-regular",
  light: "text-light",
};

type HeadingSize = keyof typeof sizeClasses;
type HeadingFont = keyof typeof fontClasses;
type HeadingWeight = keyof typeof weightClasses;

interface Props {
  htmlheading?: string;
  size?: HeadingSize;
  font?: HeadingFont;
  weight?: HeadingWeight;
  stylingclasses?: string;
}

// Henter de valgte værdier fra Astro.props og sender resten videre til HTML-tagget.
const {
  htmlheading = "h2",
  size = "h2",
  font = "sans",
  weight = "regular",
  stylingclasses = "",
  ...rest
} = Astro.props as Props;
const Htmlheading = htmlheading;
---

<Htmlheading
  {...rest}
  class:list={[
    stylingclasses,
    sizeClasses[size],
    fontClasses[font],
    weightClasses[weight],
  ]}><slot /></Htmlheading
>
