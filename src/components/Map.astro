---
/* =========================================================
   INTERAKTIVT KORT-KOMPONENT (Leaflet.js + Alpine.js)
   ========================================================= */

interface MapLocation {
  id: string;
  lokation: string;
  address: string;
  lat: number;
  lng: number;
  cities: string[];
  holds: string[];
}

interface Props {
  eyebrow?: string;
  title?: string;
  locations?: MapLocation[];
  bgClass?: string;
  eyebrowClass?: string;
  titleClass?: string;
}

const {
  eyebrow = "Hold oversigt",
  title = "Find En Træner Nær Dig",
  locations = [],
  bgClass = "bg-transparent",
  eyebrowClass = "text-(--button-main-bg)",
  titleClass = "text-(--neutral-500)",
} = Astro.props;

const initialLocation = locations.length > 0 ? locations[0] : { id: "" };
---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<section 
  class:list={["px-(--page-space-inline) py-(--section-space-y) select-none", bgClass]}
  x-data={`interactiveMap({ 
    locations: ${JSON.stringify(locations)}, 
    activeId: '${initialLocation.id}' 
  })`}
>
  <div class="max-w-6xl mx-auto">
    <div class="mb-8">
      <p class:list={["text-size-14 uppercase tracking-wider font-semibold mb-1", eyebrowClass]}>{eyebrow}</p>
      <h2 class:list={["text-size-30 font-display font-bold md:text-size-40", titleClass]}>{title}</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      
      <div class="lg:col-span-2 border border-(--neutral-300) rounded-lg overflow-hidden min-h-[400px] md:min-h-[450px] relative shadow-sm z-10">
        <div x-ref="mapCanvas" class="absolute inset-0 w-full h-full"></div>
      </div>

      <div class="flex flex-col gap-3 max-h-[450px] overflow-y-auto pr-1" role="tablist" aria-label="Træningslokationer">
        <h3 class="text-size-13 font-semibold uppercase tracking-wider text-(--neutral-400) mb-1">Lokationer</h3>
        
        {locations.length > 0 ? (
          locations.map((loc) => (
            <button
              type="button"
              role="tab"
              id={`tab-${loc.id}`}
              aria-controls={`panel-${loc.id}`}
              class="w-full text-left inline-flex flex-col font-sans font-semibold transition-all duration-200 hover:scale-[1.01] active:scale-[0.99] focus:outline-none cursor-pointer px-6 py-5 text-size-18 rounded-md outline-none focus-visible:ring-2 focus-visible:ring-(--main-400)"
              @click={`selectLocation('${loc.id}')`}
              :aria-selected={`activeId === '${loc.id}' ? 'true' : 'false'`}
              :class={`activeId === '${loc.id}' 
                ? 'bg-(--button-main-bg) text-(--button-main-text) shadow-sm' 
                : 'bg-(--main-100) text-(--neutral-500) hover:bg-(--main-200)'
              `}
            >
              <span class="font-display text-size-20 leading-tight">
                {loc.lokation}
              </span>
              {loc.address && (
                <span 
                  class="text-size-14 font-sans leading-tight opacity-80 mt-1 font-normal"
                  :class={`activeId === '${loc.id}' ? 'text-(--button-main-text)' : 'text-(--neutral-500)'`}
                >
                  {loc.address}
                </span>
              )}
            </button>
          ))
        ) : (
          <p class="text-(--neutral-400) text-size-15 italic">Ingen lokationer fundet</p>
        )}
      </div>
    </div>

    <div 
      class="border-t border-(--neutral-300) pt-6" 
      x-show="activeLocation && (activeLocation.cities.length > 0 || activeLocation.holds.length > 0)"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 transform translate-y-2"
      x-transition:enter-end="opacity-100 transform translate-y-0"
      id="details-panel"
    >
      <h3 class="text-size-13 font-semibold uppercase tracking-wider text-(--neutral-400) mb-4">Udbud på lokationen</h3>
      
      <div class="flex flex-wrap gap-3">
        <template x-for="by in activeLocation?.cities" :key="by">
          <span 
            class="inline-flex items-center justify-center font-sans font-semibold leading-none h-[40px] px-5 text-size-14 rounded-md bg-(--button-secondary-bg) text-(--button-secondary-text) capitalize shadow-xs"
            x-text="by"
          ></span>
        </template>

        <template x-for="hold in activeLocation?.holds" :key="hold">
          <span 
            class="inline-flex items-center justify-center font-sans font-semibold leading-none h-[40px] px-5 text-size-14 rounded-md bg-(--button-primary-bg) text-(--button-primary-text) uppercase shadow-xs"
            x-text="hold"
          ></span>
        </template>
      </div>
    </div>
  </div>
</section>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script is:inline>
  function interactiveMap(config) {
    return {
      locations: config.locations,
      activeId: config.activeId,
      map: null,
      markers: {},

      get activeLocation() {
        return this.locations.find(loc => loc.id === this.activeId);
      },

      init() {
        // Sikrer os at Leaflet er klar i DOM'en inden initialisering
        if (!window.L || this.locations.length === 0) return;

        // Byg kortbasen inde i vores x-ref canvas
        this.map = window.L.map(this.$refs.mapCanvas, {
          zoomControl: true,
          scrollWheelZoom: false,
          attributionControl: false,
        });

        // Hent et stilrent open-source kortlag uden unødvendig støj
        window.L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png").addTo(this.map);

        // Map alle koordinater ind som brugerdefinerede pins
        this.locations.forEach(loc => {
          const marker = window.L.marker([loc.lat, loc.lng], {
            icon: this.createIcon(loc.id === this.activeId)
          }).addTo(this.map);

          // Klik-event på selve kortets markør
          marker.on("click", () => {
            this.selectLocation(loc.id);
            // Scroll blidt til detaljesektionen hvis man er på mobil
            if (window.innerWidth < 1024) {
              document.getElementById('details-panel')?.scrollIntoView({ behavior: 'smooth' });
            }
          });

          this.markers[loc.id] = marker;
        });

        this.centerMap(true); // Første center uden flyTo-animation
      },

      selectLocation(id) {
        this.activeId = id;
        
        // Genberegn aktive klasser på tværs af alle pins på kortet
        Object.keys(this.markers).forEach(key => {
          this.markers[key].setIcon(this.createIcon(key === this.activeId));
        });

        this.centerMap(false);
      },

      centerMap(isInitial = false) {
        if (!this.activeLocation || !this.map) return;

        const targetCoords = [this.activeLocation.lat, this.activeLocation.lng];
        const zoomLevel = 11;

        if (isInitial) {
          this.map.setView(targetCoords, zoomLevel);
        } else {
          // Premium flyTo animation i stedet for det hårde setView
          this.map.flyTo(targetCoords, zoomLevel, {
            animate: true,
            duration: 0.8,
            easeLinearity: 0.25
          });
        }
      },

      createIcon(isActive) {
        return window.L.divIcon({
          className: "md-pin-container",
          iconSize: [40, 40],
          iconAnchor: [20, 20], // Centreret præcist i midten af ringen
          html: `
            <div class="md-pin__wrap ${isActive ? 'is-active' : ''}">
              <div class="md-pin__ring">
                <div class="md-pin__dot"></div>
              </div>
            </div>
          `,
        });
      }
    };
  }
</script>

<style is:global>
  .md-pin-container {
    background: transparent !important;
    border: none !important;
  }
  .md-pin__wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .md-pin__wrap.is-active {
    transform: scale(1.3);
  }
  .md-pin__ring {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background: var(--neutral-0, #ffffff);
    border: 3px solid var(--button-main-bg, #606c38);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
  }
  .md-pin__wrap.is-active .md-pin__ring {
    border-color: var(--button-primary-bg, #283618);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
  }
  .md-pin__dot {
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background: var(--button-main-bg, #606c38);
    transition: background-color 0.3s ease;
  }
  .md-pin__wrap.is-active .md-pin__dot {
    background: var(--button-primary-bg, #283618);
  }
</style>