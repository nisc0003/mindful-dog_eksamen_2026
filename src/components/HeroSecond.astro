---
import Heading from "./Heading.astro";
import Text from "./Text.astro";
import LinkButton from "./Buttons__&_links/LinkButton.astro";

interface ButtonConfig {
  label: string;
  color: "main" | "primary" | "secondary" | "accent" | "neutral" | "outline";
  href: string;
}

interface Props {
  imageSrc: string;
  imageAlt?: string;
  imagePosition?: "left" | "right"; // Defaults to left on desktop. Mobile is always image-top.
  hasVideo?: boolean;
  topLabel?: string;
  title: string;
  tags?: string[];
  description?: string;
  buttons?: ButtonConfig[];
}

const {
  imageSrc,
  imageAlt = "Hero billede",
  imagePosition = "left",
  hasVideo = false,
  topLabel,
  title,
  tags = [],
  description,
  buttons = [],
} = Astro.props as Props;
---

<section
  class="w-full px-[var(--page-space-inline)] py-[var(--section-space-y)]"
>
  <div
    class={`max-w-[1440px] mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-16 lg:gap-24 ${
      imagePosition === "right" ? "md:flex-row-reverse" : ""
    }`}
  >
    {/* Image / Video Container */}
    <div class="relative w-full md:w-1/2">
      <img
        src={imageSrc}
        alt={imageAlt}
        class="aspect-[4/3] h-auto w-full rounded-md object-cover shadow-sm md:aspect-square lg:aspect-[4/3]"
      />
      {
        hasVideo && (
          <button
            aria-label="Afspil video"
            class="absolute inset-0 m-auto flex h-16 w-16 cursor-pointer items-center justify-center rounded-full bg-(--main-400)/90 text-(--neutral-100) transition-transform hover:scale-105 hover:bg-(--main-500) md:h-20 md:w-20"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="ml-1 h-8 w-8 md:h-10 md:w-10"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z"
              />
            </svg>
          </button>
        )
      }
    </div>

    {/* Content Container */}
    <div class="flex w-full flex-col items-start md:w-1/2">
      {
        topLabel && (
          <Text
            size="label_1"
            weight="semibold"
            stylingclasses="text-(--neutral-400) mb-2"
          >
            {topLabel}
          </Text>
        )
      }

      <Heading
        htmlheading="h2"
        size="h2"
        font="display"
        weight="bold"
        stylingclasses="text-(--neutral-500) mb-4"
      >
        {title}
      </Heading>

      {
        tags.length > 0 && (
          <div class="mb-6 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="text-size-12 rounded-sm bg-(--main-400) px-3 py-1 font-semibold tracking-wider text-(--neutral-100) uppercase">
                {tag}
              </span>
            ))}
          </div>
        )
      }

      {
        description && (
          <Text
            size="p2"
            stylingclasses="text-(--neutral-500) mb-8 max-w-[600px]"
          >
            {description}
          </Text>
        )
      }

      {
        buttons.length > 0 && (
          <div class="mt-auto flex flex-wrap gap-3 md:gap-4">
            {buttons.map((btn) => (
              <LinkButton href={btn.href} color={btn.color} label={btn.label} />
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>
