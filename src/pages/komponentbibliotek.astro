---
/* =========================================================
   Komponentbibliotek
   Demo side til Button + Link komponenter
   ========================================================= */

import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";

/* =========================
   Available sizes
   ========================= */
const sizes = ["sm", "md", "lg", "xl"] as const;

/* =========================
   Available colors
   ========================= */
const colors = [
  "primary",
  "secondary",
  "accent",
  "neutral",
  "outline",
] as const;

/* =========================
   Demo cards for filtering
   ========================= */
const cards = [
  { id: 1, title: "Hvalpetræning", category: "Hvalp", location: "NYC" },
  { id: 2, title: "Reaktiv hund", category: "Voksen", location: "LA" },
  { id: 3, title: "Tricks & sjov", category: "Tricks", location: "Chicago" },
  { id: 4, title: "Snor uden træk", category: "Voksen", location: "NYC" },
  { id: 5, title: "Hvalpe-socialklub", category: "Hvalp", location: "Chicago" },
  { id: 6, title: "Avanceret lydighed", category: "Voksen", location: "LA" },
];

/* =========================
   Long text for read-more demo
   ========================= */
const longText =
  "Mindful-Dog Academy arbejder med en holistisk og relationsbaseret tilgang til hundetræning. Vi tror på at træning bygger broer mellem mennesker og hunde gennem nærvær, tydelig kommunikation og gensidig respekt — ikke gennem dominans eller frygt. Hver hund er unik, og vores forløb tilpasses individuelt.";
---

<MainLayout title="Komponentbibliotek — Button & Link">
  {
    /* =========================================================
     PAGE WRAPPER
     ========================================================= */
  }
  <div class="space-y-16 py-8 font-sans text-(--neutral-500)">
    {
      /* =========================================================
       1. SEARCH BUTTON DEMO
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">1. Search button</h2>

      <div class="flex flex-col gap-4">
        {
          sizes.map((s) => (
            <Button
              variant="search"
              size={s}
              color="primary"
              placeholder={`Søg (${s})…`}
              label="Søg"
            />
          ))
        }
      </div>
    </section>

    {
      /* =========================================================
       2. DROPDOWN FILTER
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">2. Dropdown button</h2>

      <p class="text-size-15 mb-3 text-(--neutral-400)">
        Filtrerer kort-griddet nedenfor på kategori.
      </p>

      <div class="flex flex-wrap items-center gap-4">
        {
          sizes.map((s) => (
            <Button
              variant="dropdown"
              size={s}
              color="outline"
              label="Vælg kategori"
              options={["Hvalp", "Voksen", "Tricks"]}
              dropdownTarget="category"
            />
          ))
        }
      </div>
    </section>

    {
      /* =========================================================
       3. LOCATION FILTER
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">3. Location button</h2>

      <p class="text-size-15 mb-3 text-(--neutral-400)">
        Filtrerer kort-griddet nedenfor på lokation.
      </p>

      <div class="space-y-3">
        {
          sizes.map((s) => (
            <div class="flex flex-wrap items-center gap-3">
              <Button
                variant="location"
                size={s}
                color="primary"
                location="NYC"
                label="NYC"
              />
              <Button
                variant="location"
                size={s}
                color="secondary"
                location="LA"
                label="LA"
              />
              <Button
                variant="location"
                size={s}
                color="accent"
                location="Chicago"
                label="Chicago"
              />
            </div>
          ))
        }
      </div>
    </section>

    {
      /* =========================================================
       FILTERED CARD GRID
       ========================================================= */
    }
    <section
      x-data={`{
        cards: ${JSON.stringify(cards)},
        visible() {
          const f = this.$store.filters;
          return this.cards.filter(c =>
            (!f.location || c.location === f.location) &&
            (!f.category || c.category === f.category)
          );
        }
      }`}
    >
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-display text-size-30">Kort-grid (filtreret)</h2>

        {/* Reset filters */}
        <button
          type="button"
          @click="$store.filters.reset()"
          class="underline hover:text-(--link-text-hover)"
        >
          Nulstil filtre
        </button>
      </div>

      {/* Cards grid */}
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        <template x-for="card in visible()" :key="card.id">
          <article class="rounded-md border p-5">
            <h3 class="font-display text-size-20 mb-1" x-text="card.title"></h3>
            <p class="text-size-14 text-(--neutral-400)">
              <span x-text="card.category"></span> ·
              <span x-text="card.location"></span>
            </p>
          </article>
        </template>

        {/* Empty state */}
        <p x-show="visible().length === 0" class="col-span-full">
          Ingen resultater for de valgte filtre.
        </p>
      </div>
    </section>

    {
      /* =========================================================
       4. STANDARD BUTTONS
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">4. Standard button</h2>

      {
        sizes.map((s) => (
          <div class="mb-4">
            <p class="text-size-12 mb-2 uppercase">size: {s}</p>

            <div class="flex flex-wrap gap-3">
              {colors.map((c) => (
                <Button
                  variant="standard"
                  size={s}
                  color={c}
                  label={c.toUpperCase()}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    {
      /* =========================================================
       5. LINK BUTTONS
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">5. Link buttons</h2>

      {
        sizes.map((s) => (
          <div class="mb-4">
            <p class="text-size-12 mb-2 uppercase">size: {s}</p>

            <div class="flex flex-wrap gap-3">
              {colors.map((c) => (
                <Link
                  variant="standard"
                  size={s}
                  color={c}
                  href="#"
                  label={c.toUpperCase()}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    {
      /* =========================================================
       6. SOCIAL LINKS
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">6. Social links</h2>

      {
        sizes.map((s) => (
          <div class="mb-4 flex items-center gap-3">
            <span class="text-size-12 w-12 uppercase">{s}</span>

            <Link
              variant="social"
              size={s}
              color="neutral"
              network="facebook"
              href="#"
            />
            <Link
              variant="social"
              size={s}
              color="neutral"
              network="x"
              href="#"
            />
            <Link
              variant="social"
              size={s}
              color="neutral"
              network="instagram"
              href="#"
            />
          </div>
        ))
      }
    </section>

    {
      /* =========================================================
       7. BREADCRUMB DEMO
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">7. Breadcrumb</h2>

      <p class="text-size-15 mb-3 text-(--neutral-400)">
        Opdaterer filter via Alpine store.
      </p>

      <Link
        variant="crawl"
        trail={[
          { label: "Home", href: "/" },
          { label: "Hold", filter: "" },
          { label: "Hvalp", filter: "Hvalp" },
          { label: "Voksen", filter: "Voksen" },
          { label: "Tricks", filter: "Tricks" },
        ]}
      />
    </section>

    {
      /* =========================================================
       8. READ MORE
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">8. Read more</h2>

      <Button
        variant="readmore"
        size="md"
        color="primary"
        fullText={longText}
        previewLength={140}
      />
    </section>

    {
      /* =========================================================
       9. VIDEO CONTROLS
       ========================================================= */
    }
    <section>
      <h2 class="font-display text-size-30 mb-4">9. Video controls</h2>

      <div class="max-w-xl space-y-4">
        <video
          id="demoVideo"
          class="w-full rounded-md"
          muted
          loop
          playsinline
          src="https://cdn.coverr.co/videos/coverr-a-puppy-running-in-the-grass-4929/1080p.mp4"
        ></video>

        <div class="flex flex-wrap gap-3">
          {
            sizes.map((s) => (
              <div class="flex gap-2">
                <Button
                  variant="playpause"
                  size={s}
                  color="primary"
                  videoTarget="#demoVideo"
                />
                <Button
                  variant="mute"
                  size={s}
                  color="outline"
                  videoTarget="#demoVideo"
                />
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</MainLayout>
