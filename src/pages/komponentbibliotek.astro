---
/* =========================================================
   KOMPONENTBIBLIOTEK
   Enkel oversigt over alle knap- og link-komponenter.
   ========================================================= */

import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Link from "../components/Buttons__&_links/Link.astro";
import SearchButton from "../components/Buttons__&_links/SearchButton.astro";
import DropdownButton from "../components/Buttons__&_links/DropdownButton.astro";
import LocationButton from "../components/Buttons__&_links/LocationButton.astro";
import StandardButton from "../components/Buttons__&_links/StandardButton.astro";
import LinkButton from "../components/Buttons__&_links/LinkButton.astro";
import SocialLink from "../components/Buttons__&_links/SocialLink.astro";
import ReadMore from "../components/Buttons__&_links/ReadMore.astro";
import Breadcrumb from "../components/Buttons__&_links/Breadcrumb.astro";

const dropdownOptions = ["Hvalp", "Voksen", "Tricks"];

const breadcrumbTrail = [
  { label: "Forside", href: "/" },
  { label: "Hold", href: "/Hold_oversigt" },
  { label: "Hvalp", filter: "Hvalp" },
  { label: "Voksen", filter: "Voksen" },
  { label: "Tricks", filter: "Tricks" },
];

const longText =
  "Mindful-Dog Academy arbejder med en holistisk og relationsbaseret tilgang til hundetræning. Vi tror på at træning bygger broer mellem mennesker og hunde gennem nærvær, tydelig kommunikation og gensidig respekt — ikke gennem dominans eller frygt.";

const videoSrc =
  "https://cdn.coverr.co/videos/coverr-a-puppy-running-in-the-grass-4929/1080p.mp4";

const headingVariants = ["h1", "h2", "h3", "h4", "h5", "h6"] as const;
const textVariants = ["p1", "p2", "p3", "p4", "label_1", "label_2"] as const;
const fontVariants = ["display", "sans"] as const;
const weightVariants = ["bold", "regular", "light"] as const;
---

<MainLayout title="Komponentbibliotek — knapper og links">
  <div class="m-4 space-y-24 py-8 text-(--neutral-500)">
    <!-- =========================================================
         0. TYPOGRAFI
    ========================================================= -->
    <section class="my-4 space-y-8 bg-white p-6">
      <Heading htmlheading="h2" size="h4" font="display" weight="bold">Overskrifter</Heading>

      <div class="grid gap-4">
        {headingVariants.map((variant) => (
          <article class="rounded-lg border border-(--neutral-200) p-4">
            <p class="mb-2 text-size-12 uppercase tracking-[0.16em] text-(--neutral-300)">{variant}</p>
            <Heading htmlheading={variant} size={variant} font="display" weight="bold">
              Mindful Dog — {variant.toUpperCase()}
            </Heading>
          </article>
        ))}
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <article class="rounded-lg border border-(--neutral-200) p-4">
          <p class="mb-3 text-size-12 uppercase tracking-[0.16em] text-(--neutral-300)">Skrifttype</p>
          <div class="space-y-3">
            {fontVariants.map((font) => (
              <Heading htmlheading="h4" size="h4" font={font} weight="regular">
                {font === "display" ? "Geologica / font-display" : "Manrope / font-sans"}
              </Heading>
            ))}
          </div>
        </article>

        <article class="rounded-lg border border-(--neutral-200) p-4">
          <p class="mb-3 text-size-12 uppercase tracking-[0.16em] text-(--neutral-300)">Vægt</p>
          <div class="space-y-3">
            {weightVariants.map((weight) => (
              <Heading htmlheading="h4" size="h4" font="display" weight={weight}>
                {weight}
              </Heading>
            ))}
          </div>
        </article>
      </div>

      <div class="grid gap-4">
        <article class="rounded-lg border border-(--neutral-200) p-4">
          <p class="mb-3 text-size-12 uppercase tracking-[0.16em] text-(--neutral-300)">Tekststørrelser</p>
          <div class="space-y-3">
            {textVariants.map((variant) => (
              <Text size={variant} font="sans" weight="regular">
                {variant} - Dette er en eksempeltekst, som viser størrelsen i typografisystemet.
              </Text>
            ))}
          </div>
        </article>

        <div class="grid gap-4 md:grid-cols-2">
          <article class="rounded-lg border border-(--neutral-200) p-4">
            <p class="mb-3 text-size-12 uppercase tracking-[0.16em] text-(--neutral-300)">Tekstfonte</p>
            <div class="space-y-3">
              {fontVariants.map((font) => (
                <Text size="p2" font={font} weight="regular">
                  {font === "display" ? "font-display bruges til markante tekster" : "font-sans bruges til brødtekst og UI"}
                </Text>
              ))}
            </div>
          </article>

          <article class="rounded-lg border border-(--neutral-200) p-4">
            <p class="mb-3 text-size-12 uppercase tracking-[0.16em] text-(--neutral-300)">Tekstvægte</p>
            <div class="space-y-3">
              {weightVariants.map((weight) => (
                <Text size="p2" font="sans" weight={weight}>
                  {weight} - Eksempel på vægt i tekstkomponenten.
                </Text>
              ))}
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- =========================================================
         1. SØGEKNAPPER
    ========================================================= -->
    <section class="my-4 space-y-6 bg-white p-6">
      <Heading htmlheading="h2" size="h4" font="display" weight="bold">Søgeknapper</Heading>

      <div class="flex flex-wrap gap-3">
        <SearchButton size="sm" />
        <SearchButton size="md" />
        <SearchButton size="lg" />
        <SearchButton size="xl" />
      </div>
    </section>

    <!-- =========================================================
         2. DROPDOWN-KNAPPER
    ========================================================= -->
    <section class="my-4 space-y-6 bg-white p-6">
      <Heading htmlheading="h2" size="h4" font="display" weight="bold">Dropdown buttons</Heading>

      <div class="flex flex-wrap gap-3">
        <DropdownButton size="sm" color="primary" options={dropdownOptions} />
        <DropdownButton size="sm" color="secondary" options={dropdownOptions} />
        <DropdownButton size="sm" color="accent" options={dropdownOptions} />
        <DropdownButton size="sm" color="main" options={dropdownOptions} />
        <DropdownButton size="sm" color="neutral" options={dropdownOptions} />
        <DropdownButton size="sm" color="outline" options={dropdownOptions} />
      </div>
      <div class="flex flex-wrap gap-3">
        <DropdownButton size="md" color="primary" options={dropdownOptions} />
        <DropdownButton size="md" color="secondary" options={dropdownOptions} />
        <DropdownButton size="md" color="accent" options={dropdownOptions} />
        <DropdownButton size="md" color="main" options={dropdownOptions} />
        <DropdownButton size="md" color="neutral" options={dropdownOptions} />
        <DropdownButton size="md" color="outline" options={dropdownOptions} />
      </div>
      <div class="flex flex-wrap gap-3">
        <DropdownButton size="lg" color="primary" options={dropdownOptions} />
        <DropdownButton size="lg" color="secondary" options={dropdownOptions} />
        <DropdownButton size="lg" color="accent" options={dropdownOptions} />
        <DropdownButton size="lg" color="main" options={dropdownOptions} />
        <DropdownButton size="lg" color="neutral" options={dropdownOptions} />
        <DropdownButton size="lg" color="outline" options={dropdownOptions} />
      </div>
      <div class="flex flex-wrap gap-3">
        <DropdownButton size="xl" color="primary" options={dropdownOptions} />
        <DropdownButton size="xl" color="secondary" options={dropdownOptions} />
        <DropdownButton size="xl" color="accent" options={dropdownOptions} />
        <DropdownButton size="xl" color="main" options={dropdownOptions} />
        <DropdownButton size="xl" color="neutral" options={dropdownOptions} />
        <DropdownButton size="xl" color="outline" options={dropdownOptions} />
      </div>
    </section>

    <!-- =========================================================
     3. LOKATIONS-KNAPPER
========================================================= -->
    <section class="my-4 space-y-6 bg-white p-6">
      <Heading htmlheading="h2" size="h4" font="display" weight="bold">Lokations-knapper</Heading>

      <div class="grid justify-items-start gap-4 md:grid-cols-2 xl:grid-cols-3">
        <LocationButton size="sm" color="main" location="Vestsjælland" />
        <LocationButton size="sm" color="primary" location="Lokation" />
        <LocationButton size="sm" color="secondary" location="Lokation" />
      </div>

      <div class="grid justify-items-start gap-4 md:grid-cols-2 xl:grid-cols-3">
        <LocationButton size="md" color="main" location="Vestsjælland" />
        <LocationButton size="md" color="primary" location="Vestsjælland" />
        <LocationButton size="md" color="secondary" location="Als" />
      </div>

      <div class="grid justify-items-start gap-4 md:grid-cols-2 xl:grid-cols-3">
        <LocationButton
          size="lg"
          color="main"
          location="Vestsjælland"
          address="Lillevej 2A, 7430 Ikast"
        />
        <LocationButton
          size="lg"
          color="primary"
          location="Lokation"
          address="Adresse, Postnr By"
        />
        <LocationButton
          size="lg"
          color="secondary"
          location="Lokation"
          address="Adresse, Postnr By"
        />
      </div>

      <div class="grid justify-items-start gap-4 md:grid-cols-2 xl:grid-cols-3">
        <LocationButton
          size="xl"
          color="main"
          location="Vestsjælland"
          address="Lillevej 2A, 7430 Ikast"
        />
        <LocationButton
          size="xl"
          color="primary"
          location="Lokation"
          address="Adresse, Postnr By"
        />
        <LocationButton
          size="xl"
          color="secondary"
          location="Lokation"
          address="Adresse, Postnr By"
        />
      </div>
    </section>
    <!-- =========================================================
         4. STANDARD-KNAPPER
    ========================================================= -->
    <section class="my-4 space-y-6 bg-white p-6">
      <Heading htmlheading="h2" size="h4" font="display" weight="bold">Standard-knapper</Heading>

      <div class="grid grid-cols-2 gap-4 md:grid-cols-5">
        <StandardButton size="sm" color="main" label="Main" />
        <StandardButton size="sm" color="primary" label="Primary" />
        <StandardButton size="sm" color="secondary" label="Secondary" />
        <StandardButton size="sm" color="accent" label="Accent" />
        <StandardButton size="sm" color="neutral" label="Neutral" />
        <StandardButton size="sm" color="outline" label="Outline" />
      </div>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-5">
        <StandardButton size="md" color="main" label="Main" />
        <StandardButton size="md" color="primary" label="Primary" />
        <StandardButton size="md" color="secondary" label="Secondary" />
        <StandardButton size="md" color="accent" label="Accent" />
        <StandardButton size="md" color="neutral" label="Neutral" />
        <StandardButton size="md" color="outline" label="Outline" />
      </div>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-5">
        <StandardButton size="lg" color="main" label="Main" />
        <StandardButton size="lg" color="primary" label="Primary" />
        <StandardButton size="lg" color="secondary" label="Secondary" />
        <StandardButton size="lg" color="accent" label="Accent" />
        <StandardButton size="lg" color="neutral" label="Neutral" />
        <StandardButton size="lg" color="outline" label="Outline" />
      </div>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-5">
        <StandardButton size="xl" color="main" label="Main" />
        <StandardButton size="xl" color="primary" label="Primary" />
        <StandardButton size="xl" color="secondary" label="Secondary" />
        <StandardButton size="xl" color="accent" label="Accent" />
        <StandardButton size="xl" color="neutral" label="Neutral" />
        <StandardButton size="xl" color="outline" label="Outline" />
      </div>
    </section>

    <!-- =========================================================
         5. LINK-KNAPPER
    ========================================================= -->
    <section class="my-4 space-y-6 bg-white p-6">
      <Heading htmlheading="h2" size="h4" font="display" weight="bold">Link-knapper</Heading>

      <div class="grid grid-cols-2 gap-4 md:grid-cols-5">
        <LinkButton size="sm" color="main" href="#" label="Main" />
        <LinkButton size="sm" color="primary" href="#" label="Primary" />
        <LinkButton size="sm" color="secondary" href="#" label="Secondary" />
        <LinkButton size="sm" color="accent" href="#" label="Accent" />
        <LinkButton size="sm" color="neutral" href="#" label="Neutral" />
        <LinkButton size="sm" color="outline" href="#" label="Outline" />

        <LinkButton size="md" color="main" href="#" label="Main" />
        <LinkButton size="md" color="primary" href="#" label="Primary" />
        <LinkButton size="md" color="secondary" href="#" label="Secondary" />
        <LinkButton size="md" color="accent" href="#" label="Accent" />
        <LinkButton size="md" color="neutral" href="#" label="Neutral" />
        <LinkButton size="md" color="outline" href="#" label="Outline" />

        <LinkButton size="lg" color="main" href="#" label="Main" />
        <LinkButton size="lg" color="primary" href="#" label="Primary" />
        <LinkButton size="lg" color="secondary" href="#" label="Secondary" />
        <LinkButton size="lg" color="accent" href="#" label="Accent" />
        <LinkButton size="lg" color="neutral" href="#" label="Neutral" />
        <LinkButton size="lg" color="outline" href="#" label="Outline" />

        <LinkButton size="xl" color="main" href="#" label="Main" />
        <LinkButton size="xl" color="primary" href="#" label="Primary" />
        <LinkButton size="xl" color="secondary" href="#" label="Secondary" />
        <LinkButton size="xl" color="accent" href="#" label="Accent" />
        <LinkButton size="xl" color="neutral" href="#" label="Neutral" />
        <LinkButton size="xl" color="outline" href="#" label="Outline" />
      </div>
    </section>

    <!-- =========================================================
         6. STANDARD-LINKS
    ========================================================= -->
    <section class="my-4 space-y-6 bg-white p-6">
      <Heading htmlheading="h2" size="h4" font="display" weight="bold">Standard links</Heading>

      <div class="flex flex-wrap gap-4">
        <Link href="#">Et almindeligt link</Link>
        <Link href="#" stylingclasses="text-(--link-text-hover)">Link med ekstra styling</Link>
        <Link href="https://www.kea.dk" target="_blank" rel="noreferrer">
          Eksternt link
        </Link>
      </div>
    </section>

    <!-- =========================================================
         7. SOCIALE LINKS
    ========================================================= -->
    <section class="my-4 space-y-6 bg-white p-6">
      <Heading htmlheading="h2" size="h4" font="display" weight="bold">Sociale links</Heading>

      <div class="grid grid-cols-3 gap-4">
        <SocialLink size="sm" network="facebook" href="#" />
        <SocialLink size="sm" network="x" href="#" />
        <SocialLink size="sm" network="instagram" href="#" />
      </div>

      <div class="grid grid-cols-3 gap-4">
        <SocialLink size="md" network="facebook" href="#" />
        <SocialLink size="md" network="x" href="#" />
        <SocialLink size="md" network="instagram" href="#" />
      </div>

      <div class="grid grid-cols-3 gap-4">
        <SocialLink size="lg" network="facebook" href="#" />
        <SocialLink size="lg" network="x" href="#" />
        <SocialLink size="lg" network="instagram" href="#" />
      </div>

      <!-- =========================================================
         8. LÆS MERE
    ========================================================= -->
      <section class="my-4 space-y-6 bg-white p-6">
        <Heading htmlheading="h2" size="h4" font="display" weight="bold">Læs mere link</Heading>

        <div class="grid gap-6">
          <ReadMore fullText={longText} />
        </div>
      </section>
      <!-- =========================================================
         9. BRØDKRUMME
    ========================================================= -->
      <section class="my-4 space-y-6 bg-white p-6">
        <Heading htmlheading="h2" size="h4" font="display" weight="bold">Brødkrumme</Heading>

        <Breadcrumb trail={breadcrumbTrail} />
      </section>
    </section>
  </div>
</MainLayout>
