---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Button from "../components/Buttons__&_links/Button.astro";
import Infobox_4 from "../components/infobox/Infobox_type_4.astro";
import MapSection from "../components/Map.astro";
import HeroMain from "../components/HeroMain.astro";
import HeroMainImage from "../assets/testimages/forside_hero.png";
import FacebookIcon from "../assets/icon/Facebook_Logo_Dark.svg";
import InstagramIcon from "../assets/icon/Instagram_Glyph_Dark.svg";
import LinkedInIcon from "../assets/icon/In-Bug_Dark.svg";

// Hent data direkte fra kilden via den præcise API-struktur
// @ts-ignore
import { getAllData } from "../assets/js/supabase_v2.js";

interface ServiceItem {
  lokation?: string;
  hold?: string;
  traener?: {
    adresse_1?: string;
    postnummer_1?: string;
    bynavn_1?: string;
  };
}

interface MapLocation {
  id: string;
  lokation: string;
  address: string;
  lat: number;
  lng: number;
  cities: string[];
  holds: string[];
}

const rawData = await getAllData();
const servicesData = (rawData as ServiceItem[]) || [];

// 1. Fast koordinat-mapping baseret på dine lokationsnavne i databasen
const coordinateMap: Record<string, { lat: number; lng: number }> = {
  vestsjælland: { lat: 55.656, lng: 11.411 },
  als: { lat: 54.891, lng: 9.974 },
  ikast: { lat: 56.141, lng: 9.152 },
  sønderjylland: { lat: 55.185, lng: 8.712 },
  skærbæk: { lat: 55.185, lng: 8.712 },
  svendborg: { lat: 55.021, lng: 10.611 },
  vejen: { lat: 55.574, lng: 9.135 },
};

// 2. Optimeret O(N) datamapping via en midlertidig ordbog (Dictionary)
const locationsDictionary: Record<string, MapLocation> = {};

servicesData.forEach((current) => {
  if (!current.lokation) return;

  const normalizedId = current.lokation.toLowerCase().trim();
  const holdName = current.hold ? current.hold.trim() : "";
  const cityName = current.traener?.bynavn_1
    ? current.traener.bynavn_1.trim()
    : "";

  if (locationsDictionary[normalizedId]) {
    // Lokationen er oprettet, tilføj unikke hold og byer til arrays
    const existing = locationsDictionary[normalizedId];
    if (holdName && !existing.holds.includes(holdName)) {
      existing.holds.push(holdName);
    }
    if (cityName && !existing.cities.includes(cityName)) {
      existing.cities.push(cityName);
    }
  } else {
    // Lokationen findes ikke endnu, opbyg adresse-streng og instantiér objektet
    const traener = current.traener;
    const addressString = traener
      ? `${traener.adresse_1 || ""}, ${traener.postnummer_1 || ""} ${traener.bynavn_1 || ""}`
          .trim()
          .replace(/^,\s*/, "") // Rens eventuelle formateringskommaer i starten
      : "";

    // Hent koordinat, eller sæt en fornuftig standard placeret i midten af Danmark hvis ukendt
    const coords = coordinateMap[normalizedId] || { lat: 56.0, lng: 11.0 };

    locationsDictionary[normalizedId] = {
      id: normalizedId,
      lokation: current.lokation,
      address: addressString,
      lat: coords.lat,
      lng: coords.lng,
      cities: cityName ? [cityName] : [],
      holds: holdName ? [holdName] : [],
    };
  }
});

// Konverter vores ordbog tilbage til et rent array som Map-komponenten forventer
const processedLocations = Object.values(locationsDictionary);

// Statiske UI elementer
const keys = [
  {
    punkt: "1",
    eyebrow: "Nøgle #1",
    title: "Overskrift",
    description: "Lorem ipsum dolor sit amet, consectetur.",
    href: "/noegle-1",
  },
  {
    punkt: "2",
    eyebrow: "Nøgle #2",
    title: "Overskrift",
    description: "Lorem ipsum dolor sit amet, consectetur.",
    href: "/noegle-2",
  },
  {
    punkt: "3",
    eyebrow: "Nøgle #3",
    title: "Overskrift",
    description: "Lorem ipsum dolor sit amet, consectetur.",
    href: "/noegle-3",
  },
  {
    punkt: "4",
    eyebrow: "Nøgle #4",
    title: "Overskrift",
    description: "Lorem ipsum dolor sit amet, consectetur.",
    href: "/noegle-4",
  },
];

type ButtonColor =
  | "main"
  | "primary"
  | "secondary"
  | "accent"
  | "neutral"
  | "outline";

const heroButtons = [
  { label: "SE VORES HOLD", color: "primary" as ButtonColor, href: "#teamet" },
];

const puppyButtons = [
  {
    size: "md" as const,
    color: "neutral" as ButtonColor,
    label: "LÆS MERE HER",
  },
  {
    size: "md" as const,
    color: "outline" as ButtonColor,
    label: "SE HOLDOVERSIGT FOR HVALPE",
    stylingclasses: "border-(--neutral-500) text-(--neutral-500)",
  },
];
---

<MainLayout title="Mindful Dog Academy - Forside">
  <section class="pb-(--section-space-y) pl-(--page-space-inline)">
    <HeroMain
      titleHtml='<span class="text-(--main-400)">Mindful Dog <br/>Academy</span>'
      subtitle="Ro og forståelse mellem dig og din hund."
      imageSrc={HeroMainImage}
      buttons={heroButtons}
    />
  </section>

  <section
    class="bg-(--main-100) px-(--page-space-inline) py-(--section-space-y)"
  >
    <Text
      size="label_1"
      font="sans"
      weight="regular"
      stylingclasses="text-(--text-label) tracking-widest uppercase"
    >
      nøgler
    </Text>
    <Heading
      htmlheading="h2"
      size="h3"
      font="display"
      weight="bold"
      stylingclasses="mb-8 md:mb-12"
    >
      Mindful-Dog Metoden - De Fire Nøgler
    </Heading>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        keys.map((k) => (
          <div key={k.punkt}>
            <Infobox_4
              punkt={k.punkt}
              topskrift={k.eyebrow}
              title={k.title}
              description={k.description}
              containerClass="rounded-md bg-(--neutral-0) p-6 shadow-xs"
              titleClass="text-(--neutral-500)"
              topskriftClass="text-(--neutral-500)"
              descriptionClass="text-(--neutral-500)"
            />
          </div>
        ))
      }
    </div>
  </section>

  <MapSection
    locations={processedLocations}
    eyebrow="Hold oversigt"
    title="Find En Træner Nær Dig"
    bgClass="bg-(--neutral-0)"
  />

  <section
    class="bg-(--accent-200) px-(--page-space-inline) py-(--section-space-y)"
  >
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-16">
      <img
        src={HeroMainImage.src}
        alt="Hundetræning video"
        class="h-full w-full rounded-md object-cover shadow-sm"
      />
      <div class="flex flex-col items-start justify-center gap-6">
        <div>
          <Text
            size="label_1"
            font="sans"
            weight="regular"
            stylingclasses="mb-2 text-(--neutral-400) tracking-widest uppercase"
          >
            trænings typer
          </Text>
          <Heading
            htmlheading="h2"
            size="h3"
            font="display"
            weight="bold"
            stylingclasses="mb-4"
          >
            Hvalpe Træning
          </Heading>
          <Text
            size="p2"
            font="sans"
            weight="regular"
            stylingclasses="text-(--neutral-500)"
          >
            Hos Mindful-Dog Academy tager vi udgangspunkt i både dig og din
            hund. Øvelserne tilpasses din hunds alder og udvikling, så I får det
            bedste fundament for et samarbejde i hverdagen.
          </Text>
        </div>

        <div class="mt-2 flex flex-wrap items-center gap-4">
          {
            puppyButtons.map((button) => (
              <Button
                key={button.label}
                size={button.size}
                color={button.color}
                label={button.label}
                stylingclasses={button.stylingclasses}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>
</MainLayout>
