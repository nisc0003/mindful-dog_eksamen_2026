---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Buttons__&_links/Button.astro";
import Heading from "../components/Heading.astro";
import Link from "../components/Buttons__&_links/Link.astro";
import Infobox from "../components/Infobox.astro";
import Text from "../components/Text.astro";
---

<MainLayout title="Forside">
  <article>
    <Heading htmlheading="h1" size="h2" font="display" weight="bold">
      Forside
    </Heading>
    <Button>Klik!</Button>
    <Text stylingclasses="mt-4 !text-size-16">
      Link til <Link href="/komponentbibliotek">Komponentbibliotek</Link>
    </Text>
  </article>
  <Infobox titel="Overskrift">
    <span slot="ikon" class="text-4xl">ℹ️</span>
    <Text>
      Dette er en infoboks. Den kan bruges til at fremhæve vigtig information.
    </Text>
  </Infobox>
</MainLayout>
