---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Button from "../components/Buttons__&_links/Button.astro";
import Link from "../components/Buttons__&_links/Link.astro";
import SocialLink from "../components/Buttons__&_links/SocialLink.astro";
import HeroMain from "../components/HeroMain.astro";
import HeroMainImage from "../assets/testimages/forside_hero.png";
import FacebookIcon from "../assets/icon/Facebook_Logo_Dark.svg";
import InstagramIcon from "../assets/icon/Instagram_Glyph_Dark.svg";
import LinkedInIcon from "../assets/icon/In-Bug_Dark.svg";

// Her kan du fetche data fra Supabase, f.eks.:
// const { data: noegler } = await supabase.from('noegler').select('*');
---

<MainLayout title="Mindful Dog Academy - Forside">
  <!-- =========================================================
       HERO SEKTION
  ========================================================= -->
  <section class="pb-(--section-space-y) pl-(--page-space-inline)">
    <HeroMain
      breadcrumbs="FORSIDE"
      titleHtml='<span class="text-(--main-400)">Mindful Dog <br/>Academy</span>'
      subtitle="Ro, mental balance og ægte forståelse mellem dig og din firbenede ven."
      imageSrc={HeroMainImage}
      buttons={[{ label: "SE VORES HOLD", color: "primary", href: "#teamet" }]}
    />
  </section>

  <!-- =========================================================
      DE FIRE NØGLER SEKTION
  ========================================================= -->
  <section
    class="bg-(--main-100) px-(--page-space-inline) py-(--section-space-y)"
  >
    <Text size="label_1" font="display" weight="semibold">INDHOLD</Text>

    <Heading htmlheading="h2" size="h3" stylingclasses="mb-8 md:mb-12">
      Mindful-Dog Metoden - De Fire Nøgler
    </Heading>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      <article
        class="flex flex-col gap-4 rounded-md bg-(--neutral-0) p-6 shadow-sm"
      >
        <div class="flex items-center gap-4">
          <div class="h-12 w-12 shrink-0 rounded-sm bg-(--main-300)"></div>
          <Heading htmlheading="h3" size="h6" weight="semibold"
            >Nøgle #1 - Overskrift</Heading
          >
        </div>
        <Text size="p3" font="sans" weight="regular"
          >Lorem ipsum dolor sit amet, consectetur adipiscing elit.</Text
        >
        <Link
          href="/noegle-1"
          label="LÆS MERE"
          stylingclasses="mt-auto text-size-12 uppercase"
        />
      </article>

      <article
        class="flex flex-col gap-4 rounded-md bg-(--neutral-0) p-6 shadow-sm"
      >
        <div class="flex items-center gap-4">
          <div class="h-12 w-12 shrink-0 rounded-sm bg-(--main-300)"></div>
          <Heading htmlheading="h3" size="h6" weight="semibold"
            >Nøgle #2 - Overskrift</Heading
          >
        </div>
        <Text size="p3" font="sans" weight="regular"
          >Lorem ipsum dolor sit amet, consectetur adipiscing elit.</Text
        >
        <Link
          href="/noegle-2"
          label="LÆS MERE"
          stylingclasses="mt-auto text-size-12 uppercase"
        />
      </article>

      <article
        class="flex flex-col gap-4 rounded-md bg-(--neutral-0) p-6 shadow-sm"
      >
        <div class="flex items-center gap-4">
          <div class="h-12 w-12 shrink-0 rounded-sm bg-(--main-300)"></div>
          <Heading htmlheading="h3" size="h6" weight="semibold"
            >Nøgle #3 - Overskrift</Heading
          >
        </div>
        <Text size="p3" font="sans" weight="regular"
          >Lorem ipsum dolor sit amet, consectetur adipiscing elit.</Text
        >
        <Link
          href="/noegle-3"
          label="LÆS MERE"
          stylingclasses="mt-auto text-size-12 uppercase"
        />
      </article>

      <article
        class="flex flex-col gap-4 rounded-md bg-(--neutral-0) p-6 shadow-sm"
      >
        <div class="flex items-center gap-4">
          <div class="h-12 w-12 shrink-0 rounded-sm bg-(--main-300)"></div>
          <Heading htmlheading="h3" size="h6" weight="semibold"
            >Nøgle #4 - Overskrift</Heading
          >
        </div>
        <Text size="p3" font="sans" weight="regular"
          >Lorem ipsum dolor sit amet, consectetur adipiscing elit.</Text
        >
        <Link
          href="/noegle-4"
          label="LÆS MERE"
          stylingclasses="mt-auto text-size-12 uppercase"
        />
      </article>
    </div>
  </section>

  <!-- =========================================================
      LOKATIONER SEKTION
  ========================================================= -->
  <section class="px-(--page-space-inline) py-(--section-space-y)">
    <Text size="label_1" stylingclasses="mb-2 text-(--text-label)"
      >LOKATIONER</Text
    >
    <Heading htmlheading="h2" size="h3" stylingclasses="mb-8"
      >Find En Træner Nær Dig</Heading
    >

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col gap-6">
        <div
          class="relative flex aspect-video w-full items-center justify-center overflow-hidden rounded-md bg-(--neutral-200)"
        >
          <span class="text-(--neutral-400)"
            >[ Interaktivt Kort Placeholder ]</span
          >
        </div>

        <div class="flex flex-wrap gap-2">
          <Button size="sm" color="main" label="Nordsjælland" />
          <Button size="sm" color="outline" label="Midtsjælland" />
          <Button size="sm" color="outline" label="Syd/Vestjælland" />
          <Button size="sm" color="outline" label="Fyn / Syddanmark" />
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <Text
          size="label_1"
          font="display"
          weight="semibold"
          stylingclasses="mb-2 lg:hidden">LOKATIONER</Text
        >

        <div class="rounded-md bg-(--main-400) p-4 text-(--neutral-100)">
          <Heading htmlheading="h4" size="h6" stylingclasses="mb-1"
            >Nordsjælland</Heading
          >
          <Text size="p4" font="sans" weight="regular"
            >Lorem ipsum dolor sit amet.</Text
          >
        </div>

        <div
          class="flex items-center justify-between rounded-md bg-(--main-100) p-4"
        >
          <div>
            <Heading htmlheading="h4" size="h6" stylingclasses="mb-1"
              >Allerød</Heading
            >
            <Text
              size="p4"
              font="sans"
              weight="regular"
              stylingclasses="text-(--text-secondary)"
              >Lorem ipsum dolor sit amet.</Text
            >
          </div>
        </div>

        <div
          class="flex items-center justify-between rounded-md bg-(--main-100) p-4"
        >
          <div>
            <Heading htmlheading="h4" size="h6" stylingclasses="mb-1"
              >Farum</Heading
            >
            <Text
              size="p4"
              font="sans"
              weight="regular"
              stylingclasses="text-(--text-secondary)"
              >Lorem ipsum dolor sit amet.</Text
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================================
      HVALPE TRÆNING SEKTION
  ========================================================= -->
  <section
    class="bg-(--accent-200) px-(--page-space-inline) py-(--section-space-y)"
  >
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-16">
      <div
        class="relative aspect-video w-full overflow-hidden rounded-md bg-(--neutral-300)"
      >
        <img
          src={HeroMainImage.src}
          alt="Hundetræning video"
          class="h-full w-full object-cover opacity-60"
        />
        <div class="absolute inset-0 flex items-center justify-center">
          <button
            class="flex h-16 w-16 cursor-pointer items-center justify-center rounded-full bg-(--neutral-0) text-(--accent-400) shadow-lg transition-transform hover:scale-105"
          >
            ▶
          </button>
        </div>
      </div>

      <div class="flex flex-col items-start gap-6 text-(--neutral-500)">
        <div>
          <Text
            size="label_1"
            font="display"
            weight="semibold"
            stylingclasses="mb-2">TRÆNING TIL HVALPE</Text
          >
          <Heading htmlheading="h2" size="h3" stylingclasses="mb-4"
            >Hvalpe Træning</Heading
          >
          <Text size="p2" font="sans" weight="regular" stylingclasses="mb-2"
            >Lorem ipsum dolor sit amet, consectetur adipiscing elit.</Text
          >
          <Text
            size="p3"
            font="sans"
            weight="regular"
            stylingclasses="opacity-80"
            >Lorem ipsum dolor sit amet, consectetur adipiscing elit.</Text
          >
        </div>

        <div class="mt-2 flex flex-wrap items-center gap-4">
          <Button size="md" color="neutral" label="LÆS MERE HER" />
          <Button
            size="md"
            color="outline"
            stylingclasses="border-(--neutral-500) text-(--neutral-500)"
            label="SE HOLDOVERSIGT FOR HVALPE"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================================
      NYHEDSBREV SEKTION
  ========================================================= -->
  <section class="px-(--page-space-inline) py-(--section-space-y)">
    <div
      class="grid grid-cols-1 gap-8 border-t border-(--neutral-200) pt-12 md:grid-cols-2 md:items-center md:pt-16"
    >
      <div class="flex flex-col gap-4">
        <Text size="label_1" stylingclasses="text-(--text-label)"
          >NYHEDSBREV</Text
        >
        <Heading htmlheading="h3" size="h4">Hold Dig Opdateret</Heading>
        <Text size="p3" stylingclasses="text-(--text-secondary)">
          Tilmeld dig vores nyhedsbrev og få tips og tricks til hundetræning og
          nye hold i dit lokalområde.
        </Text>

        <form class="mt-2 flex w-full gap-2">
          <input
            type="email"
            placeholder="Din emailadresse"
            class="flex-1 rounded-md border border-(--neutral-300) px-4 py-2 focus:ring-2 focus:ring-(--main-400) focus:outline-none"
            required
          />
          <Button
            type="submit"
            size="md"
            color="main"
            label="TILMELD"
            stylingclasses="px-6"
          />
        </form>
      </div>

      <div class="flex items-center gap-6 md:justify-end">
        <SocialLink
          href="https://www.instagram.com/"
          size="sm"
          iconSrc={InstagramIcon}
          iconAlt="Instagram"
        />
        <SocialLink
          href="https://www.facebook.com/"
          size="sm"
          iconSrc={FacebookIcon}
          iconAlt="Facebook"
        />
        <SocialLink
          href="https://www.linkedin.com/company/mindful-dog"
          size="sm"
          iconSrc={LinkedInIcon}
          iconAlt="LinkedIn"
        />
      </div>
    </div>
  </section>
</MainLayout>
