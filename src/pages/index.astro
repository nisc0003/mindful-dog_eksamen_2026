---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";
import Infobox from "../components/Infobox.astro";
---

<MainLayout title="Forside">
  <article>
    <h1>Forside</h1>
    <Button>Klik!</Button>
    <p>
      Link til <Link href="https://www.kea.dk" target="_blank"
        >En anden side</Link
      >
    </p>
  </article>
  <Infobox titel="Overskrift">
    <span slot="ikon" class="text-4xl">ℹ️</span>
    <p>
      Dette er en infoboks. Den kan bruges til at fremhæve vigtig information.
    </p>
  </Infobox>
</MainLayout>
