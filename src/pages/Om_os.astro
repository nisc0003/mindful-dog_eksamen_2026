---

<MainLayout title="Mindful Dog Academy - Om Os">
  <!-- =========================================================
       HERO SEKTION
  ========================================================= -->
  <section class="pb-(--section-space-y) pl-(--page-space-inline)">
    <HeroMain
      titleHtml='Mindful Dog <br/><span class="text-(--accent-400)">Academy</span>'
      subtitle="Mød teamet bag din hunds nye yndlingssted og lær mere om vores positive værdigrundlag."
      imageSrc={HeroMainImage}
      buttons={[{ label: "LÆS MERE", color: "secondary", href: "#teamet" }]}
    />
  </section>

  <!-- =========================================================
      FILOSOFI SEKTION
  ========================================================= -->
  <section class="px-(--page-space-inline) py-(--section-space-y)">
    <div class="max-w-3xl">
      <Text size="label_1" font="display" weight="semibold">FILOSOFI</Text>
      <Heading
        htmlheading="h2"
        size="h3"
        weight="bold"
        stylingclasses="mb-6 md:mb-8">Mindful-Dog Academy's Filosofi</Heading
      >
      <div class="space-y-4">
        <Text size="p2" font="sans" weight="regular"
          >Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad
          minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo.</Text
        >
      </div>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        philosophyCards.map((card) => (
          <Infobox_4
            punkt={card.square}
            topskrift={card.eyebrow}
            title={card.title}
            description={card.description}
            containerClass="shadow-sm"
            titleClass="text-(--neutral-500)"
            topskriftClass="text-(--neutral-500)"
            descriptionClass="text-(--neutral-500)"
          />
        ))
      }
    </div>
  </section>

  <!-- =========================================================
      MINDFUL-DOG METODEN SEKTION
  ========================================================= -->
  <section
    id="metoden"
    class="bg-(--main-100) px-(--page-space-inline) py-(--section-space-y)"
  >
    <Text size="label_1" font="display" weight="semibold">METODEN I FOKUS</Text>
    <Heading
      htmlheading="h2"
      size="h3"
      weight="bold"
      stylingclasses="mb-6 md:mb-8">Mindful-Dog Metoden</Heading
    >
    <Text size="p2" font="sans" weight="regular" stylingclasses="max-w-3xl"
      >Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
      tempor incididunt ut labore et dolore magna aliqua.</Text
    >

    <div class="mt-10 grid gap-6">
      {
        methodCards.map((card) => (
          <Infobox_3
            punkt={card.square}
            title={card.title}
            description={card.description}
            points={card.points}
            containerClass="gap-6 lg:p-12"
            headerClass="mb-2"
            bodyClass="gap-6"
            titleClass="text-(--neutral-500)"
            descriptionClass="text-(--neutral-500)"
            pointItemClass="flex flex-col gap-1"
            pointLabelClass="text-(--neutral-500)"
            pointTextClass="text-(--neutral-500)"
          />
        ))
      }
    </div>
  </section>

  <!-- =========================================================
      TEAM SEKTION
  ========================================================= -->
  <section id="teamet" class="px-(--page-space-inline) py-(--section-space-y)">
    <Text size="label_1" font="display" weight="semibold">TEAMET</Text>
    <Heading
      htmlheading="h2"
      size="h3"
      weight="bold"
      stylingclasses="mb-6 !text-size-30"
    >
      Om os
    </Heading>
    <Button>Klik!</Button>
    <p>
      Link til <Link href="https://www.kea.dk" target="_blank"
        >En anden side</Link
      >
    </p>
  </section>

  <HoldCard />
</MainLayout>
