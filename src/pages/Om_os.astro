const teamMembers = [
  {
    name: "Alexandra",
    location: "Nordsjælland",
    slug: "alexandra",
    image: alexandra,
  },
  { name: "Eva", location: "København", slug: "eva", image: eva },
  {
    name: "Freja",
    location: "Midtsjælland",
    slug: "freja",
    image: freja,
  },
  {
    name: "Grace",
    location: "Hovedkontor",
    slug: "grace-hidalgo",
    image: grace,
  },
  { name: "Pia", location: "Fyn", slug: "pia", image: pia },
  { name: "Sabine", location: "Sydsjælland", slug: "sabine", image: sabine },
  { name: "Isabell", location: "Vestjylland", slug: "isabell", image: isabell },
];

const graceDescription = `Jeg er Grace Hidalgo, grundlæggeren af  Mindful-Dog Academy. Min rejse begyndte for over 20 år siden, da jeg stod i en situation, hvor jeg havde udfordringer med min egen  hund. Det var først da jeg  tilfældigt mødte en dyreadfærdsterapeut, at jeg fik den indsigt og  hjælp, jeg savnede. Den viden følte jeg en stærk trang til at  videregive. da det for mig var en kæmpe øjenåbner, at arbejde ud fra  positive indlæringsmetoder. Jeg underviste i dette i over 10 år i  mit eget træningscenter. Jeg opdagede dog undervejs, at der manglede en vigtig dimension. Derfor udviklede jeg Mindful-Dog metoden, en tilgang der går ud over den traditionelle træningstilgang.`;
const graceQuote = `"Når du som ejer lærer at forstå både hunden og dig selv, kan du opnå en dyb, harmonisk relation med din hund – en relation der ikke kun er bygget på teknikker og kommandoer."`;
---

<MainLayout title="Mindful Dog Academy - Om Os">
  <!-- =========================================================
       HERO SEKTION
  ========================================================= -->
  <section class="pb-(--section-space-y) pl-(--page-space-inline)">
    <HeroMain
      titleHtml='Mindful Dog <br/><span class="text-(--accent-400)">Academy</span>'
      subtitle="Mød teamet bag din hunds nye yndlingssted og lær mere om vores positive værdigrundlag."
      imageSrc={HeroMainImage}
      buttons={[
        { label: "LÆS MERE", color: "secondary", href: "#teamet" },
        { label: "VORES METODE", color: "secondary", href: "#metoden" },
        { label: "TEAMET", color: "secondary", href: "#teamet" },
      ]}
    />
  </section>

  <!-- =========================================================
      FILOSOFI SEKTION
  ========================================================= -->
  <section class="px-(--page-space-inline) py-(--section-space-y)">
    <div class="max-w-3xl">
      <Text
        size="label_1"
        font="display"
        weight="light"
        stylingclasses="tracking-widest uppercase"
      >
        FILOSOFI
      </Text>
      <Heading
        htmlheading="h2"
        size="h3"
        weight="bold"
        stylingclasses="mb-6 md:mb-8">Mindful-Dog Academy's Filosofi</Heading
      >
      <div class="space-y-4">
        <Text size="p2" font="sans" weight="regular"
          >Mindful-Dog metoden er udviklet af Grace Hidalgo, og er opbygget ud
          fra 4 nøgler. Dette er kernen af Mindful-Dog metoden, og noget alle
          vores instruktører tager udgangspunkt i ved træning - lige meget hvor
          i landet de befinder sig.</Text
        >
      </div>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        philosophyCards.map((card) => (
          <Infobox_4
            punkt={card.square}
            topskrift={card.eyebrow}
            title={card.title}
            description={card.description}
            readMorePreviewLength={card.readMorePreviewLength}
            containerClass="shadow-sm"
            titleClass="text-(--neutral-500)"
            topskriftClass="text-(--neutral-500)"
            descriptionClass="text-(--neutral-500)"
          />
        ))
      }
    </div>
  </section>

  <!-- =========================================================
      MINDFUL-DOG METODEN SEKTION
  ========================================================= -->
  <section
    id="metoden"
    class="bg-(--main-100) px-(--page-space-inline) py-(--section-space-y)"
  >
    <Text
      size="label_1"
      font="display"
      weight="light"
      stylingclasses="tracking-widest uppercase"
    >
      vores metode
    </Text>
    <Heading
      htmlheading="h2"
      size="h3"
      weight="bold"
      stylingclasses="mb-6 md:mb-8">Mindful-Dog Metoden</Heading
    >
    <Text size="p2" font="sans" weight="regular" stylingclasses="max-w-3xl"
      >Hundens adfærd formes ikke kun af teknikker, men af den energi, de
      mønstre og den indre tilstand, vi bringer ind i samspillet. Når du lærer
      at aflæse både din hund og dig selv, bliver det muligt at ændre negative
      mønstre – både hos dig og hos din hund. Her handler det ikke om kontrol,
      men om <span class="font-bold">forståelse, tryghed og samarbejde.</span
      ></Text
    >

    <div class="mt-10 grid gap-6">
      {
        methodCards.map((card) => (
          <Infobox_3
            punkt={card.square}
            title={card.title}
            description={card.description}
            readMorePreviewLength={card.readMorePreviewLength}
            points={card.points}
            containerClass="gap-6 lg:p-12"
            headerClass="mb-2"
            bodyClass="gap-6"
            titleClass="text-(--neutral-500)"
            descriptionClass="text-(--neutral-500)"
            pointItemClass="flex flex-col gap-1"
            pointLabelClass="text-(--neutral-500)"
            pointTextClass="text-(--neutral-500)"
          />
        ))
      }
    </div>
  </section>

  <!-- =========================================================
      TEAM SEKTION
  ========================================================= -->
  <section id="teamet" class="px-(--page-space-inline) py-(--section-space-y)">
    <Text
      size="label_1"
      font="display"
      weight="light"
      stylingclasses="tracking-widest uppercase">TEAMET</Text
    >
    <Heading
      htmlheading="h2"
      size="h3"
      weight="bold"
      stylingclasses="mb-6 md:mb-8">Alle Vores Instruktører</Heading
    >
    <Text
      size="p2"
      font="sans"
      weight="regular"
      stylingclasses="mb-12 max-w-3xl"
      >Mindful-Dog Academy er en eksklusiv kæde af certificerede instruktører.
      Lige meget hvor du er i landet, bruger vi samme teknikker og følger
      værdierne i Mindful-Dog Metoden.</Text
    >

    <div class="grid grid-cols-2 gap-8 gap-y-12 md:grid-cols-3 lg:grid-cols-4">
      {
        teamMembers.map((member) => (
          <TeamMemberCard
            name={member.name}
            location={member.location}
            image={member.image}
            href={`/Instruktoer_profil/${member.slug}`}
          />
        ))
      }
    </div>
  </section>

  <!-- =========================================================
      GRACE HIDALGO SEKTION
  ========================================================= -->
  <section class="px-(--page-space-inline) pb-(--section-space-y)">
    <HeroSecond
      imageSrc={HeroSecondImage}
      imagePosition="left"
      topLabel="STIFTER & EJER"
      title="Grace Hidalgo"
      layoutGapClass="gap-[clamp(1rem,2vw,2.75rem)]"
      contentGapClass="gap-[clamp(0.75rem,1.4vw,1.5rem)]"
      buttons={[
        { label: "LÆS MERE", color: "secondary", href: "#teamet" },
        { label: "KONTAKT", color: "outline", href: "/kontakt" },
      ]}
    >
      <div
        class="max-w-3xl space-y-4 pl-[clamp(1rem,4vw,4rem)] md:pl-[clamp(1.5rem,4vw,5rem)]"
      >
        <Text
          size="p1"
          font="display"
          weight="regular"
          stylingclasses="text-(--neutral-500)"
        >
          {graceQuote}
        </Text>
        <Text
          size="p2"
          font="sans"
          weight="light"
          stylingclasses="text-(--neutral-500) uppercase tracking-wider"
        >
          {graceDescription}
        </Text>
      </div>
    </HeroSecond>
  </section>
</MainLayout>
