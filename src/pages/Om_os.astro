    points: [
      {
        label: "1.1",
        text: "Er interesseret i en positiv tilgang til hundetræning, med hjælp og guidance fra vores Mindful-Dog træner.",
      },
      {
        label: "1.2",
        text: "Leder efter holdtræning, workshops eller ene undervisning med din hund. Vi tilbyder endda hjemmevurdering af hundens adfærd.",
      },
    ],
  },
  {
    square: "2.0",
    title: "Hvad Er Grundlaget For Mindful-Dog Metoden?",
    readMorePreviewLength: 150,
    descriptionPreview:
      "Metoden er udviklet af vores stifter Grace Hidalgo, der har uddannelserne pædagog, terapeut, coach og hundeadfærdsinstruktør. Derfor bygger metoden på Grace Hidalgo’s egne erfaringer med både hunde og mennesker i træningsmomenter. Hun mente at der manglede en dimension i den hundetræning hun var uddannet i, og udviklede derfor Mindful-Dog metoden ud fra observationer som disse:",
    description:
      "Metoden er udviklet af vores stifter Grace Hidalgo, der har uddannelserne pædagog, terapeut, coach og hundeadfærdsinstruktør. Derfor bygger metoden på Grace Hidalgo’s egne erfaringer med både hunde og mennesker i træningsmomenter. Hun mente at der manglede en dimension i den hundetræning hun var uddannet i, og udviklede derfor Mindful-Dog metoden ud fra observationer som disse:",
    points: [
      {
        label: "2.1",
        text: "Hundens adfærd spejler i høj grad ejerens energi og tilstand. Ejerens indre verden påvirker hundens adfærd.",
      },
      {
        label: "2.2",
