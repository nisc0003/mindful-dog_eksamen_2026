---
//@ts-nocheck
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";
import ProductCard from "../components/ProductCard.astro";
import Shop from "../components/Shop.astro";
---

<MainLayout title="Hold oversigt">
  <article>
    <Heading
      htmlheading="h1"
      size="h2"
      font="display"
      weight="bold"
      stylingclasses="mb-6 !text-size-30"
    >
      Hold oversigt
    </Heading>
    <Button>Klik!</Button>
  </article>
  <Shop selectedLokation={Astro.url.searchParams.get("lokation") || "Alle"} />
</MainLayout>
