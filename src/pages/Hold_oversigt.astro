---
//@ts-nocheck
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Buttons__&_links/Button.astro";
import Heading from "../components/Heading.astro";
import Link from "../components/Buttons__&_links/Link.astro";
import Text from "../components/Text.astro";
import Shop from "../components/Shop.astro";
import { Image } from "astro:assets";
import SpringHund from "../assets/img/hold_img.webp";
import Gavekort from "../components/Gavekort.astro";

import Vandhund from "../assets/img/EKSAMEN_EDIT-7263.webp";
---

<MainLayout title="Hold oversigt">
  <article>
    <div class="mx-auto grid max-w-[68vw] grid-cols-3 content-center">
      <Heading
        htmlheading="h1"
        size="h1"
        font="display"
        weight="bold"
        stylingclasses="mb-6 col-span-2"
      >
        Find dit hold
      </Heading>
      <Image
        src={SpringHund}
        alt="Billede af Bichon Havanais der springer, uden baggrund"
        class="m-auto h-auto w-full"
      />
    </div>
  </article>
  <section>
    <Shop selectedLokation={Astro.url.searchParams.get("lokation") || "Alle"} />
    <div class="p4 mx-auto my-4 grid grid-cols-3 gap-4 place-self-center">
      <span class="col-span-2">
        <Gavekort />
      </span>
      <Image
        src={Vandhund}
        alt="Billede af Graces ene hund, Nascha"
        class="m-auto aspect-9/10 max-h-80 w-auto object-cover"
      />
    </div>
  </section>
</MainLayout>
