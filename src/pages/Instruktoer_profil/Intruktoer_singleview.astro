---
import MainLayout from "../../layouts/MainLayout.astro";
import Button from "../../components/Buttons__&_links/Button.astro";
import Heading from "../../components/Heading.astro";
import Link from "../../components/Buttons__&_links/Link.astro";
import Text from "../../components/Text.astro";

export function getStaticPaths() {
  return [{ params: { slug: "grace-hidalgo" } }];
}
---

<MainLayout title="Instruktør profil">
  <article>
    <Heading
      htmlheading="h1"
      size="h2"
      font="display"
      weight="bold"
      stylingclasses="mb-6 !text-size-30"
    >
      Instruktør profil
    </Heading>
    <Button>Klik!</Button>
    <Text stylingclasses="mt-4 !text-size-16">
      Link til <Link href="https://www.kea.dk">En anden side</Link>
    </Text>
  </article>
</MainLayout>
