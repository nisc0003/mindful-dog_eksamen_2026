---
//@ts-nocheck
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";
import ProductCard from "../components/ProductCard.astro";
import HoldSkema from "../components/HoldSkema.astro";
---

<MainLayout title="Hold oversigt">
  <article>
    <h1>Hold Skema</h1>
    <Button>Klik!</Button>
    <p>
      Link til <Link href="https://www.kea.dk" target="_blank"
        >En anden side</Link
      >
    </p>
  </article>
  <HoldSkema selectedHold={Astro.url.searchParams.get("hold") || "Alle"} />
</MainLayout>
